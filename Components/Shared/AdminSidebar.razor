@using CBOS.Components.Services
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@rendermode InteractiveServer
<aside class="sidebar @(isCollapsed ? "collapsed" : "")">
    <div class="sidebar-header">
        <div class="brand-container">
            <img src="images/cbos-logo.png" alt="CBOS Logo" class="brand-logo" />
            <div class="brand-text">
                <span class="brand-title">CBOS</span>
                <span class="brand-sub">ADMIN WORKSPACE</span>
            </div>
        </div>
        <button class="toggle-btn" @onclick="ToggleSidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </button>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-group">
            <span class="nav-group-label">OVERVIEW</span>
            <NavLink class="nav-item"
                     href="/admin/app"
                     Match="NavLinkMatch.All"
                     ActiveClass="active"
                     data-nav="dashboard">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                </span>
                <span>Dashboard</span>
            </NavLink>
        </div>

        <div class="nav-group">
            <span class="nav-group-label">COMMUNITY</span>
            <NavLink class="nav-item"
                     href="/admin/feed"
                     ActiveClass="active"
                     data-nav="feed">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                    </svg>
                </span>
                <span>Community Feed</span>
            </NavLink>
        </div>

        <div class="nav-group">
            <span class="nav-group-label">MANAGEMENT</span>
            <NavLink class="nav-item"
                     href="/admin/incidents"
                     ActiveClass="active"
                     data-nav="incidents">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                        <line x1="12" y1="9" x2="12" y2="13"></line>
                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg>
                </span>
                <span>Incidents</span>
            </NavLink>

            <NavLink class="nav-item"
                     href="/admin/appointments"
                     ActiveClass="active"
                     data-nav="appointments">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </span>
                <span>Appointments</span>
            </NavLink>

            <NavLink class="nav-item"
                     href="/admin/verification"
                     ActiveClass="active"
                     data-nav="verification">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </span>
                <span>Verification</span>
                <span class="badge">3</span>
            </NavLink>
        </div>

        <div class="nav-group">
            <span class="nav-group-label">SYSTEM</span>
            <NavLink class="nav-item"
                     href="/admin/settings"
                     ActiveClass="active"
                     data-nav="settings">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                </span>
                <span>Settings</span>
            </NavLink>
        </div>
    </nav>

    <div class="sidebar-footer">
        <button class="logout-btn" @onclick="Logout">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1-2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
            </span>
            <span>Sign Out</span>
        </button>
    </div>
</aside>

@code {
    [Inject] private NavigationManager Navigation { get; set; }
    [Inject] private AdminSupabase AdminSupabase { get; set; }
    [Inject] private ProtectedSessionStorage ProtectedSessionStorage { get; set; }

    private bool isCollapsed = false;

    private void ToggleSidebar()
    {
        isCollapsed = !isCollapsed;
    }

    private async Task Logout()
    {
        try
        {
            var result = await ProtectedSessionStorage.GetAsync<string>("adminSessionKey");
            if (result.Success && !string.IsNullOrWhiteSpace(result.Value))
            {
                await AdminSupabase.DeleteSession(result.Value);
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error during logout: {ex.Message}");
        }
        finally
        {
            await ProtectedSessionStorage.DeleteAsync("adminSessionKey");
            Navigation.NavigateTo("/Admin/Login");
        }
    }
}