@using Microsoft.AspNetCore.Components
@using CBOS.Components.Services
@inject NavigationManager Navigation
@inject AdminSupabase AdminSupabase
@inject AuthService AuthService
@inject Supabase.Client Supabase
@rendermode InteractiveServer

<div class="navbar-top">
    <div class="navbar-container">

        <!-- Logo and Search -->
        <div class="navbar-left">
            <a href="/app" class="navbar-logo">
                <img src="/images/cbos-logo.png" alt="CBOS" class="navbar-logo-img" />
            </a>
            <div class="search-box">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" placeholder="Search" class="search-input" />
            </div>
        </div>

        <!-- Welcome -->
        <div class="navbar-center">
            <span class="welcome-text">
                Welcome back@(!string.IsNullOrEmpty(AuthService.FirstName) ? $", {AuthService.FirstName}" : "")!
            </span>
        </div>

        <!-- Nav Items -->
        <div class="navbar-right">
            <NavLink href="/app/make-post" class="nav-icon-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14M5 12h14"/>
                </svg>
                <span class="nav-label">Start Post</span>
            </NavLink>

            <NavLink href="/app/reports" class="nav-icon-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                </svg>
                <span class="nav-label">Reports</span>
            </NavLink>

            <NavLink href="/app/appointments" class="nav-icon-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8"  y1="2" x2="8"  y2="6"/>
                    <line x1="3"  y1="10" x2="21" y2="10"/>
                </svg>
                <span class="nav-label">Appointments</span>
            </NavLink>

            <NavLink href="/app/incidents" class="nav-icon-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span class="nav-label">Services</span>
            </NavLink>

            <NavLink href="/app/notifications" class="nav-icon-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
                <span class="nav-label">Notifications</span>
            </NavLink>

            <NavLink href="/app/profile" class="nav-icon-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <span class="nav-label">Profile</span>
            </NavLink>

            <button @onclick="Logout" class="nav-icon-item logout-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                <span class="nav-label">Logout</span>
            </button>
        </div>
    </div>
</div>

<style>
    .navbar-top {
        width: 100%;
        background: linear-gradient(90deg, #0099ff 0%, #0066ff 100%);
        box-shadow: 0 2px 8px rgba(0, 102, 255, 0.25);
        position: sticky;
        top: 0;
        z-index: 100;
        box-sizing: border-box;
        overflow: hidden;
    }

    .navbar-container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 100%;
        padding: 0 1rem;
        height: 56px;
        box-sizing: border-box;
        gap: 1rem;
    }

    .navbar-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-shrink: 0;
    }

    .navbar-logo {
        display: flex;
        align-items: center;
        text-decoration: none;
    }

    .navbar-logo-img {
        width: 32px;
        height: 32px;
        object-fit: contain;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: rgba(255,255,255,0.18);
        border-radius: 20px;
        padding: 0.35rem 0.75rem;
        gap: 0.4rem;
    }

    .search-icon {
        color: rgba(255,255,255,0.8);
        flex-shrink: 0;
    }

    .search-input {
        background: transparent;
        border: none;
        outline: none;
        color: #fff;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        font-size: 0.85rem;
        width: 140px;
    }

    .search-input::placeholder { color: rgba(255,255,255,0.65); }

    .navbar-center {
        flex: 1;
        text-align: center;
    }

    .welcome-text {
        color: rgba(255,255,255,0.9);
        font-size: 0.88rem;
        font-weight: 500;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        white-space: nowrap;
    }

    .navbar-right {
        display: flex;
        align-items: center;
        gap: 0.15rem;
        flex-shrink: 0;
    }

    .nav-icon-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.15rem;
        padding: 0.4rem 0.6rem;
        border: none;
        background: transparent;
        color: rgba(255,255,255,0.8);
        border-radius: 8px;
        cursor: pointer;
        text-decoration: none;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        transition: background 0.15s, color 0.15s;
        min-width: 52px;
    }

    .nav-icon-item:hover,
    .nav-icon-item.active {
        background: rgba(255,255,255,0.18);
        color: #fff;
    }

    .nav-label {
        font-size: 0.65rem;
        font-weight: 500;
        white-space: nowrap;
    }

    .logout-btn:hover {
        background: rgba(255, 80, 80, 0.3);
        color: #fff;
    }

    @@media (max-width: 900px) {
        .search-input { width: 80px; }
        .navbar-center { display: none; }
        .nav-label { display: none; }
        .nav-icon-item { min-width: unset; padding: 0.5rem; }
    }

    @@media (max-width: 600px) {
        .search-box { display: none; }
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated && Supabase.Auth.CurrentSession?.User != null)
        {
            var session = Supabase.Auth.CurrentSession;
            var firstName = session.User.UserMetadata
                ?.GetValueOrDefault("first_name")
                ?.ToString() ?? "";
            AuthService.SetSession(session, firstName);
        }
    }

    private async Task Logout()
    {
        await Supabase.Auth.SignOut();
        AuthService.ClearSession();
        Navigation.NavigateTo("/login", replace: true);
    }
}