@page "/app/profile"
@layout MainLayout
@using CBOS.Components.Services
@using CBOS.Services
@inject VerificationService VerificationSvc
@inject AuthService AuthSvc

<div class="profile-page-wrapper">
    <h1 class="profile-header">Profile Information</h1>

    <div class="status-container-white">
        <div class="status-card-gray">
            <span class="account-status-text">Account Status</span>
            
            <div class="status-indicator d-flex align-items-center">
                <span class="status-label-text me-2">Status:</span>
                
                @if (_isStatusLoading)
                {
                    <span class="badge bg-secondary rounded-pill custom-badge">Loading…</span>
                }
                else
                {
                    <span class="badge @_statusToneClass rounded-pill custom-badge">@_statusLabel</span>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_statusDescription) && !_isStatusLoading && _statusLabel != "No Submission")
    {
        <div class="status-description-text">@_statusDescription</div>
    }

    <NavLink class="btn btn-verify mt-2" href="/user/verify">
        Verify account
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-shield-check" viewBox="0 0 16 16">
            <path d="M5.338 1.59a61 61 0 0 0-2.837.856.48.48 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533.12.057.218.095.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .1-.025c.076-.023.174-.061.294-.118.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56"/>
            <path d="M10.854 5.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647a.5.5 0 0 1 .708 0"/>
        </svg>
    </NavLink>
</div>

@code {
    private bool _isStatusLoading = true;
    private string _statusLabel = "No Submission";
    private string _statusDescription = "";
    private string _statusToneClass = "bg-secondary";

    protected override async Task OnInitializedAsync()
    {
        await LoadVerificationStatusAsync();
    }

    private async Task LoadVerificationStatusAsync()
    {
        _isStatusLoading = true;
        if (!AuthSvc.IsAuthenticated)
        {
            SetStatus("Not Authenticated");
            _isStatusLoading = false;
            return;
        }

        var userEmail = AuthSvc.UserEmail ?? string.Empty;
        var accessToken = AuthSvc.CurrentSession?.AccessToken ?? string.Empty;

        if (string.IsNullOrWhiteSpace(userEmail) || string.IsNullOrWhiteSpace(accessToken))
        {
            SetStatus($"Missing Info: Email={userEmail}, Token={!string.IsNullOrEmpty(accessToken)}");
            _isStatusLoading = false;
            return;
        }

        var userId = await VerificationSvc.GetUserProfileIdAsync(userEmail, accessToken);
        if (userId == null || userId <= 0)
        {
            SetStatus($"User ID Not Found for {userEmail}");
            _isStatusLoading = false;
            return;
        }

        var status = await VerificationSvc.GetUserVerificationStatusAsync(userId.Value, accessToken);
        if (status == null) 
        {
            SetStatus("No Submission"); // Originally mapped to null
        } 
        else 
        {
            SetStatus(status);
        }
        
        _isStatusLoading = false;
    }

    private void SetStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status) || string.Equals(status, "No Submission", StringComparison.OrdinalIgnoreCase))
        {
            _statusLabel = "No Submission";
            _statusDescription = "";
            _statusToneClass = "bg-secondary";
            return;
        }

        if (string.Equals(status, "Pending", StringComparison.OrdinalIgnoreCase))
        {
            _statusLabel = "Pending";
            _statusDescription = "Submitted a ticket for admin review";
            _statusToneClass = "bg-warning text-dark"; // Added text-dark for better contrast on yellow
            return;
        }

        if (string.Equals(status, "Approved", StringComparison.OrdinalIgnoreCase) || string.Equals(status, "Verified", StringComparison.OrdinalIgnoreCase))
        {
            _statusLabel = "Verified";
            _statusDescription = "Admin approved";
            _statusToneClass = "bg-success";
            return;
        }

        if (string.Equals(status, "Rejected", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "Declined", StringComparison.OrdinalIgnoreCase))
        {
            _statusLabel = "Rejected";
            _statusDescription = "Admin rejected";
            _statusToneClass = "bg-danger";
            return;
        }

        _statusLabel = status;
        _statusDescription = "Verification status recorded.";
        _statusToneClass = "bg-secondary";
    }
}