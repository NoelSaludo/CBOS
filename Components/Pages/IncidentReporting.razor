@page "/app/incidents"
@layout MainLayout

<div class="services-container">
    <div class="services-main">
        <h1 class="services-title">Service Center and Tracker</h1>

        <!-- Reports Status Section -->
        <div class="section-card">
            <div class="section-header">
                <h2>Reports Status</h2>
                <a href="#" class="see-all-link">See all Reports</a>
            </div>
            <div class="reports-list">
                <div class="report-item">
                    <div class="report-info">
                        <h3>Uncollected garbage</h3>
                        <div class="report-meta">
                            <span class="badge badge-complaint">Complaint</span>
                            <span class="report-label">Type:</span>
                        </div>
                    </div>
                    <div class="report-status">
                        <span class="report-label">Status:</span>
                        <span class="status-badge status-pending">Pending</span>
                        <button class="expand-btn">▶</button>
                    </div>
                </div>
                <div class="report-item">
                    <div class="report-info">
                        <h3>Street Brawl at Lopez St.</h3>
                        <div class="report-meta">
                            <span class="badge badge-emergency">Emergency</span>
                            <span class="report-label">Type:</span>
                        </div>
                    </div>
                    <div class="report-status">
                        <span class="report-label">Status:</span>
                        <span class="status-badge status-responded">Responded</span>
                        <button class="expand-btn">▶</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Appointments Tracker Section -->
        <div class="section-card">
            <div class="section-header">
                <h2>Appointments Tracker</h2>
                <a href="#" class="see-all-link">See all Appointments</a>
            </div>
            <div class="appointments-list">
                <div class="appointment-item">
                    <div class="appointment-info">
                        <h3>November 24, 2024 - Complaint Hearing</h3>
                    </div>
                    <div class="appointment-status">
                        <span class="status-badge status-approved">Approved</span>
                        <button class="expand-btn">▶</button>
                    </div>
                </div>
                <div class="appointment-item">
                    <div class="appointment-info">
                        <h3>November 17, 2024 - Complaint Hearing</h3>
                    </div>
                    <div class="appointment-status">
                        <span class="status-badge status-reschedule">Reschedule</span>
                        <button class="expand-btn">▶</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Community Posts Status Section -->
        <div class="section-card">
            <div class="section-header">
                <h2>Community Posts Status</h2>
                <a href="#" class="see-all-link">See all Posts</a>
            </div>
            <div class="posts-list">
                <div class="post-item">
                    <div class="post-info">
                        <h3>Missing Orange Cat</h3>
                    </div>
                    <div class="post-status">
                        <span class="status-badge status-urgent">Urgent</span>
                        <button class="expand-btn">▶</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="services-sidebar">
        <!-- Hotlines Card -->
        <div class="sidebar-card hotlines-card">
            <h3 class="sidebar-title">Hotlines</h3>
            <div class="hotlines-image">[HOTLINES IMAGE]</div>
        </div>

        <!-- Available Services Card -->
        <div class="sidebar-card">
            <h3 class="sidebar-title">Available Services</h3>
            <div class="services-list-sidebar">
                <div class="service-item">
                    <h4>Document Request</h4>
                    <p>Birth certificates, barangay clearance</p>
                </div>
                <div class="service-item">
                    <h4>Complaint & Mediation</h4>
                    <p>Settle disputes peacefully</p>
                </div>
                <div class="service-item">
                    <h4>Permits & Clearance</h4>
                    <p>Business and event permits</p>
                </div>
                <div class="service-item">
                    <h4>Community Programs</h4>
                    <p>Local activities and events</p>
                </div>
            </div>
        </div>
    </div>
</div>

