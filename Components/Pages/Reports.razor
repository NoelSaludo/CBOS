@page "/app/reports"
@layout MainLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject Supabase.Client Supabase
@inject CBOS.Components.Services.AuthService AuthService
@inject IHttpClientFactory HttpClientFactory
@using CBOS.Components.Model
@using System.Text.Json

<div class="report-container">
    <img src="/images/city-bg.png" class="report-city-bg" alt="" />
    <div class="report-overlay"></div>

    <div class="report-card">
        <div class="report-header">
            <button class="back-btn" @onclick="GoBack">←</button>
            <h1>File a Report</h1>
            <div class="header-spacer"></div>
        </div>

        @if (!isVerified)
        {
            <div class="blocked-screen">
                <div class="blocked-icon-ring">
                    <span class="blocked-lock">🔒</span>
                </div>
                <h2 class="blocked-title">Verification Required</h2>
                <p class="blocked-text">
                    Your account must be verified before you can file a report with the barangay.
                </p>

                <div class="blocked-steps">
                    <div class="blocked-step">
                        <div class="step-icon">📄</div>
                        <div class="step-info">
                            <div class="step-label">Upload Documents</div>
                            <div class="step-desc">Valid ID or birth certificate</div>
                        </div>
                    </div>
                    <div class="step-arrow">›</div>
                    <div class="blocked-step">
                        <div class="step-icon">🔍</div>
                        <div class="step-info">
                            <div class="step-label">Admin Review</div>
                            <div class="step-desc">Usually within 1–2 days</div>
                        </div>
                    </div>
                    <div class="step-arrow">›</div>
                    <div class="blocked-step">
                        <div class="step-icon">✅</div>
                        <div class="step-info">
                            <div class="step-label">Get Verified</div>
                            <div class="step-desc">File reports to the barangay</div>
                        </div>
                    </div>
                </div>

                <div class="blocked-actions">
                    <a href="/user/verify" class="btn-verify">🛡️ Verify My Account</a>
                    <button class="btn-back" @onclick="GoBack">Go Back</button>
                </div>
            </div>
        }
        else
        {

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="report-error">⚠ @errorMessage</div>
        }

        <div class="report-content">

            @* ── LEFT: Report Type ── *@
            <div class="report-types">
                <p class="type-label">What kind of report?</p>

                @foreach (var type in reportTypes)
                {
                    <div class="type-group @(selectedReportType == type.Key ? "active" : "")">
                        <button class="type-btn @(selectedReportType == type.Key ? "selected" : "")"
                                @onclick="@(() => SelectReportType(type.Key))">
                            <span class="type-dot" style="background:@type.Value"></span>
                            @type.Key
                        </button>
                    </div>
                }
            </div>

            <div class="report-col-divider"></div>

            @* ── CENTER: Form ── *@
            <div class="report-form">
                <div class="field-group">
                    <label>Header</label>
                    <input type="text"
                           @bind="reportHeader"
                           placeholder="Brief title for your report" />
                </div>

                <div class="field-group">
                    <label>Description</label>
                    <textarea @bind="reportDescription"
                              placeholder="Provide detailed information about your report..."
                              rows="5"></textarea>
                </div>

                <div class="field-group">
                    <label>Photo or Video <span class="optional-tag">optional</span></label>

                    <div class="media-drop-zone" @onclick="HandleAttachMedia">
                        @if (uploadedMedia.Count > 0)
                        {
                            <div class="media-gallery" @onclick:stopPropagation="true">
                                @foreach (var (index, media) in uploadedMedia.Select((m, i) => (i, m)))
                                {
                                    @if (index < 3)
                                    {
                                        <div class="media-item">
                                            <img src="@media" alt="Media @index" />
                                            <button type="button" class="remove-media-btn" @onclick="@(() => RemoveMedia(index))" @onclick:stopPropagation="true">×</button>
                                        </div>
                                    }
                                }
                                @if (uploadedMedia.Count > 3)
                                {
                                    <div class="media-item more-indicator">
                                        <div class="more-count">+@(uploadedMedia.Count - 3)</div>
                                    </div>
                                }
                            </div>
                            <button type="button" class="attach-btn" @onclick:stopPropagation="true" @onclick="HandleAttachMedia">
                                📎 Add more
                            </button>
                        }
                        else
                        {
                            <div class="media-drop-icon">🖼️</div>
                            <div class="media-drop-hint">Click to attach photos or videos</div>
                            <button type="button" class="attach-btn" @onclick:stopPropagation="true" @onclick="HandleAttachMedia">
                                📎 Browse files
                            </button>
                        }
                    </div>

                    <InputFile @ref="fileInput"
                               id="reportFileInput"
                               style="display:none;"
                               accept="image/*,video/*"
                               OnChange="HandleFileUpload"
                               multiple />
                </div>
            </div>

            <div class="report-col-divider"></div>

            @* ── RIGHT: Notice & Submit ── *@
            <div class="report-side">
                <div class="notice-panel">
                    <div class="notice-panel-icon">📋</div>
                    <div class="notice-title">Notice</div>
                    <div class="notice-text">
                        After submission of your report, it will be reviewed by barangay admins. Expect updates on the status of your report.
                    </div>
                </div>

                <div class="status-legend">
                    <div class="status-item"><span class="dot pending"></span> Pending</div>
                    <div class="status-item"><span class="dot approved"></span> Approved</div>
                    <div class="status-item"><span class="dot rejected"></span> Rejected</div>
                </div>

                <button class="submit-btn" @onclick="HandleSubmit" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner"></span>
                        <span>Submitting...</span>
                    }
                    else
                    {
                        <span>Submit Report</span>
                    }
                </button>
            </div>

        </div>
        }
    </div>
</div>

@if (showSuccess)
{
    <div class="success-overlay">
        <div class="success-card">
            <div class="success-icon">✅</div>
            <h2>Report Submitted!</h2>
            <p>Your report is pending admin review. You'll be updated on its status.</p>
            <button class="success-btn" @onclick="GoBack">Back</button>
        </div>
    </div>
}

<style>
    .report-container {
        position: fixed;
        top: 56px;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        box-sizing: border-box;
        background: linear-gradient(160deg, #00d4ff 0%, #0099ff 45%, #0066ff 100%);
        overflow: hidden;
    }

    .report-city-bg {
