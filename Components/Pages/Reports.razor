@page "/app/reports"
@layout MainLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject Supabase.Client Supabase
@inject CBOS.Components.Services.AuthService AuthService
@using CBOS.Components.Model

<div class="reports-wrapper">
    <div class="reports-container">
        <!-- Back Button -->
        <button class="back-button" @onclick="GoBack">
            <span class="back-arrow">←</span>
        </button>

        <!-- Title -->
        <h1 class="reports-title">File a Report</h1>

        <!-- Report Type Selection -->
        <div class="report-type-section">
            <p class="report-question">What kind of report are you making?</p>
            <div class="report-type-buttons">
                <button 
                    type="button" 
                    class="report-type-btn suggestion-btn @(selectedReportType == "Suggestion" ? "active" : "")"
                    @onclick="@(() => SelectReportType("Suggestion"))">
                    Suggestion
                </button>
                <button 
                    type="button" 
                    class="report-type-btn complaint-btn @(selectedReportType == "Complaint" ? "active" : "")"
                    @onclick="@(() => SelectReportType("Complaint"))">
                    <span class="checkmark">✓</span> Complaint
                </button>
                <button 
                    type="button" 
                    class="report-type-btn emergency-btn @(selectedReportType == "Emergency" ? "active" : "")"
                    @onclick="@(() => SelectReportType("Emergency"))">
                    Emergency
                </button>
                <button 
                    type="button" 
                    class="report-type-btn other-btn @(selectedReportType == "Other" ? "active" : "")"
                    @onclick="@(() => SelectReportType("Other"))">
                    Other
                </button>
            </div>
        </div>

        <!-- Form -->
        <form @onsubmit="HandleSubmit">
            <!-- Header/Topic Section -->
            <div class="form-section">
                <label class="section-label">Header</label>
                <input 
                    type="text"
                    class="header-input"
                    @bind="reportHeader"
                    placeholder="Brief title for your report"
                />
            </div>

            <!-- Description Section -->
            <div class="form-section">
                <label class="section-label">Add description to your report</label>
                <textarea 
                    class="report-textarea"
                    @bind="reportDescription"
                    placeholder="Provide detailed information about your report..."
                    rows="6">
                </textarea>
            </div>

            <!-- Media Section -->
            <div class="form-section">
                <label class="section-label">Add photo or video to your report (optional)</label>
                
                @if (uploadedMedia.Count > 0)
                {
                    <div class="media-gallery">
                        @foreach (var (index, media) in uploadedMedia.Select((m, i) => (i, m)))
                        {
                            @if (index < 3)
                            {
                                <div class="media-item">
                                    <img src="@media" alt="Media @index" />
                                    <button type="button" class="remove-media-btn" @onclick="@(() => RemoveMedia(index))">×</button>
                                </div>
                            }
                        }
                        @if (uploadedMedia.Count > 3)
                        {
                            <div class="media-item more-indicator">
                                <div class="more-count">+@(uploadedMedia.Count - 3)</div>
                            </div>
                        }
                    </div>
                }

                <button type="button" class="attach-media-btn" @onclick="HandleAttachMedia">
                    Attach media
                </button>
                <InputFile 
                    @ref="fileInput" 
                    id="reportFileInput"
                    style="display:none;" 
                    accept="image/*,video/*"
                    OnChange="HandleFileUpload" 
                    multiple
                />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }

            <!-- Submit Button -->
            <button type="submit" class="submit-button" disabled="@isSubmitting">
                @(isSubmitting ? "Submitting..." : "Submit")
            </button>
        </form>

        @if (showSuccess)
        {
            <div class="success-overlay">
                <div class="success-card">
                    <h2>Report Submitted!</h2>
                    <p>Your report is pending admin review. You'll be updated on its status.</p>
                    <button type="button" class="submit-button" @onclick="GoBack">Back</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string selectedReportType = "Complaint";
    private string reportHeader = "";
    private string reportDescription = "";
    private List<string> uploadedMedia = new List<string>();
    private InputFile? fileInput;
    private bool isSubmitting;
    private bool showSuccess;
    private string errorMessage = "";

    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/app");
    }

    private void SelectReportType(string type)
    {
        selectedReportType = type;
    }

    private static string MapCategoryToEnum(string label) => label switch
    {
        "Suggestion" => "suggestion",
        "Complaint"  => "complaint",
        "Emergency"  => "emergency",
        "Other"      => "others",
        _            => "others"
    };

    private async Task HandleAttachMedia()
    {
        await TriggerFileInput();
    }

    private async Task TriggerFileInput()
    {
        try
        {
            await JS.InvokeVoidAsync("clickElement", "reportFileInput");
        }
        catch
        {
            // Fallback if JS interop fails
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        await ProcessFileUpload(e);
    }

    private async Task ProcessFileUpload(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles();
        foreach (var file in files)
        {
            try
            {
                var stream = file.OpenReadStream(maxAllowedSize: 5242880); // 5MB
                var bytes = new byte[stream.Length];
                await stream.ReadAsync(bytes);
                var mediaPreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
                uploadedMedia.Add(mediaPreview);
                await stream.DisposeAsync();
            }
            catch
            {
                // Handle file read error
            }
        }
    }

    private void RemoveMedia(int index)
    {
        if (index >= 0 && index < uploadedMedia.Count)
        {
            uploadedMedia.RemoveAt(index);
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = "";

        if (!AuthService.IsAuthenticated || string.IsNullOrEmpty(AuthService.UserEmail))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (string.IsNullOrWhiteSpace(reportHeader))
        {
            errorMessage = "Please enter a header for your report.";
            return;
        }

        if (string.IsNullOrWhiteSpace(reportDescription))
        {
            errorMessage = "Please enter a description for your report.";
            return;
        }

        isSubmitting = true;

        try
        {
            var profile = await Supabase
                .From<UserProfile>()
                .Match(new Dictionary<string, string> { { "emailaddress", AuthService.UserEmail } })
                .Single();

            if (profile == null)
            {
                errorMessage = "Unable to find your user profile. Please log in again.";
                return;
            }

            var newReport = new Report
            {
                UserId = profile.Id,
                Category = MapCategoryToEnum(selectedReportType),
                Title = reportHeader.Trim(),
                Content = reportDescription.Trim()
            };

            var insertedReport = await Supabase.From<Report>().Insert(newReport);
            var reportId = insertedReport.Models.FirstOrDefault()?.Id ?? 0;

            if (reportId == 0)
            {
                errorMessage = "Report was created but the ID could not be retrieved.";
                return;
            }

            try
            {
                var ticket = new Ticket
                {
                    Type = "report",
                    SourceId = reportId,
                    SubmittedBy = profile.Id,
                    Status = "Pending"
                };

                await Supabase.From<Ticket>().Insert(ticket);
            }
            catch
            {
                // Compensating delete: if ticket creation fails, remove the orphan report
                await Supabase.From<Report>()
                    .Where(r => r.Id == reportId)
                    .Delete();
                throw;
            }

            selectedReportType = "Complaint";
            reportHeader = "";
            reportDescription = "";
            uploadedMedia.Clear();
            showSuccess = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to submit report: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}

