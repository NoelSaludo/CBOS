    .media-drop-zone:hover { border-color: #0066ff; background: #eff5ff; }

    .media-drop-icon { font-size: 1.6rem; line-height: 1; }

    .media-drop-hint { font-size: 0.78rem; color: #94a3b8; }

    /* ── Success Overlay ── */
    .success-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .success-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        max-width: 380px;
        width: 90%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }

    .success-icon { font-size: 2.5rem; margin-bottom: 12px; }

    .success-card h2 {
        color: #0066ff;
        margin: 0 0 10px 0;
        font-size: 1.4rem;
        font-weight: 700;
    }

    .success-card p {
        color: #64748b;
        margin: 0 0 24px 0;
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .success-btn {
        background: linear-gradient(90deg, #0099ff, #0066ff);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 10px 32px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 3px 10px rgba(0,102,255,0.3);
    }

    @@media (max-width: 1000px) {
        .report-container { overflow-y: auto; align-items: flex-start; }
        .report-content { flex-direction: column; }
        .report-card { margin: 16px 0; }
    }

    @@media (max-width: 640px) {
        .report-card { border-radius: 12px; }
        .report-header, .report-content { padding: 14px; }
        .report-header h1 { font-size: 1.2rem; }
    }
</style>

@code {
    private string selectedReportType = "Complaint";
    private string reportHeader = "";
    private string reportDescription = "";
    private List<string> uploadedMedia = new List<string>();
    private InputFile? fileInput;
    private bool isSubmitting;
    private bool showSuccess;
    private string errorMessage = "";
    private bool isVerified = true;

    private readonly Dictionary<string, string> reportTypes = new()
    {
        ["Suggestion"] = "#10b981",
        ["Complaint"]  = "#f59e0b",
        ["Emergency"]  = "#ef4444",
        ["Other"]      = "#6366f1"
    };

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated || string.IsNullOrEmpty(AuthService.UserEmail))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var profile = await Supabase
            .From<UserProfile>()
            .Match(new Dictionary<string, string> { { "emailaddress", AuthService.UserEmail } })
            .Single();

        if (profile != null)
        {
            isVerified = await CheckIsVerifiedAsync(profile.Id);
        }
    }

    private async Task<bool> CheckIsVerifiedAsync(long userId)
    {
        var supabaseUrl = Environment.GetEnvironmentVariable("SUPABASE_URL");
        var supabaseKey = Environment.GetEnvironmentVariable("SUPABASE_KEY");
        var accessToken = AuthService.CurrentSession?.AccessToken;

        if (string.IsNullOrEmpty(supabaseUrl) || string.IsNullOrEmpty(supabaseKey))
            return false;

        var token = string.IsNullOrEmpty(accessToken) ? supabaseKey : accessToken;
        var url = $"{supabaseUrl}/rest/v1/verification_tickets?userid=eq.{userId}&status=in.(Approved,Verified)&select=id&limit=1";

        using var request = new HttpRequestMessage(HttpMethod.Get, url);
        request.Headers.Add("apikey", supabaseKey);
        request.Headers.Add("Authorization", $"Bearer {token}");

        var http = HttpClientFactory.CreateClient();
        var response = await http.SendAsync(request);
        if (!response.IsSuccessStatusCode) return false;

        var json = await response.Content.ReadAsStringAsync();
        using var doc = JsonDocument.Parse(json);
        return doc.RootElement.ValueKind == JsonValueKind.Array && doc.RootElement.GetArrayLength() > 0;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/app");
    }

    private void SelectReportType(string type)
    {
        selectedReportType = type;
    }

    private static string MapCategoryToEnum(string label) => label switch
    {
        "Suggestion" => "suggestion",
        "Complaint"  => "complaint",
        "Emergency"  => "emergency",
        "Other"      => "others",
        _            => "others"
    };

    private async Task HandleAttachMedia()
    {
        await TriggerFileInput();
    }

    private async Task TriggerFileInput()
    {
        try
        {
            await JS.InvokeVoidAsync("clickElement", "reportFileInput");
        }
        catch
        {
            // Fallback if JS interop fails
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        await ProcessFileUpload(e);
    }

    private async Task ProcessFileUpload(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles();
        foreach (var file in files)
        {
            try
            {
                var stream = file.OpenReadStream(maxAllowedSize: 5242880); // 5MB
                var bytes = new byte[stream.Length];
                await stream.ReadAsync(bytes);
                var mediaPreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
                uploadedMedia.Add(mediaPreview);
                await stream.DisposeAsync();
            }
            catch
            {
                // Handle file read error
            }
        }
    }

    private void RemoveMedia(int index)
    {
        if (index >= 0 && index < uploadedMedia.Count)
        {
            uploadedMedia.RemoveAt(index);
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = "";

        if (!AuthService.IsAuthenticated || string.IsNullOrEmpty(AuthService.UserEmail))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (string.IsNullOrWhiteSpace(reportHeader))
        {
            errorMessage = "Please enter a header for your report.";
            return;
        }

        if (string.IsNullOrWhiteSpace(reportDescription))
        {
            errorMessage = "Please enter a description for your report.";
            return;
        }

        isSubmitting = true;

        try
        {
            var profile = await Supabase
                .From<UserProfile>()
                .Match(new Dictionary<string, string> { { "emailaddress", AuthService.UserEmail } })
                .Single();

            if (profile == null)
            {
                errorMessage = "Unable to find your user profile. Please log in again.";
                return;
            }

            var newReport = new Report
            {
                UserId = profile.Id,
                Category = MapCategoryToEnum(selectedReportType),
                Title = reportHeader.Trim(),
                Content = reportDescription.Trim(),
                CreatedAt = DateTime.UtcNow
            };

            var insertedReport = await Supabase.From<Report>().Insert(newReport);
            var reportId = insertedReport.Models.FirstOrDefault()?.Id ?? 0;

            if (reportId == 0)
            {
                errorMessage = "Report was created but the ID could not be retrieved.";
                return;
            }

            try
            {
                var ticket = new Ticket
                {
                    Type = "report",
                    SourceId = reportId,
                    SubmittedBy = profile.Id,
                    Status = "Pending"
                };

                await Supabase.From<Ticket>().Insert(ticket);
            }
            catch
            {
                // Compensating delete: if ticket creation fails, remove the orphan report
                await Supabase.From<Report>()
                    .Where(r => r.Id == reportId)
                    .Delete();
                throw;
            }

            selectedReportType = "Complaint";
            reportHeader = "";
            reportDescription = "";
            uploadedMedia.Clear();
            showSuccess = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to submit report: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
