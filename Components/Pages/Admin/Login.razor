@page "/Admin/Login"
@layout AdminLayout

@using System.ComponentModel.DataAnnotations

@inject NavigationManager Navigation
@inject ILogger<Login> Logger
@inject AdminSupabase AdminSupabase

@rendermode InteractiveServer

<div class="login-card align-content-center">
    <div class="login-header">
        <h2>Welcome</h2>
        <h3>CBOS Batangas</h3>
    </div>
    <EditForm Model="@Model" OnValidSubmit="OnValidSubmit" FormName="admin-login-form">
        <DataAnnotationsValidator/>
        <ValidationSummary/>
        @if (!string.IsNullOrEmpty(LoginWarning))
        {
            <div class="alert alert-warning" role="alert">
                @LoginWarning
            </div>
        }
        <div class="mb-3">
            <InputText class="form-control capsule"
                       id="adminId"
                       placeholder="Administrator ID"
                       @bind-Value="Model.id"/>
        </div>
        <div class="mb-3">
            <div class="password-field">
                <InputText class="form-control password-input capsule"
                           id="password"
                           placeholder="Password"
                           @bind-Value="Model.password"/>
            </div>
        </div>
        <button type="submit" class="btn btn-primary submit-btn">Submit</button>
    </EditForm>
</div>


@code {
    private AdminLoginModel? Model;
    private string? LoginWarning;
 
    protected override void OnInitialized()
    {
        Model = new();
    }

    public async Task OnValidSubmit()
    {
        Logger.LogInformation("Attempting admin login with ID: {AdminId}", Model?.id);
        var result = AdminSupabase.IsAdminValid(Model?.id ?? string.Empty, Model?.password ?? string.Empty).Result;

        if (result.isValid)
        {
            // TODO: How to create a session for the admin
            Navigation.NavigateTo("/admin/app");
        }
        else
        {
            LoginWarning = "Invalid administrator ID or password. Please try again.";
            Logger.LogWarning("Admin login failed for ID: {AdminId}", Model?.id);
        }
        
    }


    public class AdminLoginModel
    {
        [Required]
        [StringLength(50, MinimumLength = 3, ErrorMessage = "ID must be between 3 and 50 characters.")]
        public string? id { get; set; }
        [Required]
        public string? password { get; set; }
    }
}