<div class="analytics-grid">
    <div class="stat-card">
        @if (IsLoading)
        {
            <div class="stat-card-skeleton">
                <div class="skeleton skeleton-icon"></div>
                <div class="skeleton skeleton-trend"></div>
                <div class="stat-info-skeleton">
                    <div class="skeleton skeleton-number"></div>
                    <div class="skeleton skeleton-label"></div>
                </div>
            </div>
        }
        else
        {
            <div class="stat-card-top">
                <div class="stat-icon-wrapper green">
                    <span class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                    </span>
                </div>
                <div class="stat-trend up">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                    <span>Total</span>
                </div>
            </div>
            <div class="stat-info">
                <div class="stat-number-wrapper">
                    <p class="stat-number">@VerifiedUsersCount.ToString("N0")</p>
                </div>
                <h3>FULLY VERIFIED USERS</h3>
            </div>
        }
    </div>
    <div class="stat-card">
        @if (IsLoading)
        {
            <div class="stat-card-skeleton">
                <div class="skeleton skeleton-icon"></div>
                <div class="skeleton skeleton-trend"></div>
                <div class="stat-info-skeleton">
                    <div class="skeleton skeleton-number"></div>
                    <div class="skeleton skeleton-label"></div>
                </div>
            </div>
        }
        else
        {
            <div class="stat-card-top">
                <div class="stat-icon-wrapper orange">
                    <span class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                    </span>
                </div>
                <div class="stat-trend neutral">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="8" y1="12" x2="16" y2="12"></line></svg>
                    <span>Registered</span>
                </div>
            </div>
            <div class="stat-info">
                <div class="stat-number-wrapper">
                    <p class="stat-number">@UnverifiedUsersCount.ToString("N0")</p>
                </div>
                <h3>PARTIALLY UNVERIFIED</h3>
            </div>
        }
    </div>
    <div class="stat-card">
        @if (IsLoading)
        {
            <div class="stat-card-skeleton">
                <div class="skeleton skeleton-icon"></div>
                <div class="skeleton skeleton-trend"></div>
                <div class="stat-info-skeleton">
                    <div class="skeleton skeleton-number"></div>
                    <div class="skeleton skeleton-label"></div>
                </div>
            </div>
        }
        else
        {
            <div class="stat-card-top">
                <div class="stat-icon-wrapper red">
                    <span class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                            <line x1="12" y1="9" x2="12" y2="13"></line>
                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                        </svg>
                    </span>
                </div>
                <div class="stat-trend up">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                    <span>+@IncidentsTodayCount today</span>
                </div>
            </div>
            <div class="stat-info">
                <div class="stat-number-wrapper">
                    <p class="stat-number">@TotalIncidentsCount.ToString("N0")</p>
                </div>
                <h3>INCIDENT REPORTS</h3>
            </div>
        }
    </div>
    <div class="stat-card">
        @if (IsLoading)
        {
            <div class="stat-card-skeleton">
                <div class="skeleton skeleton-icon"></div>
                <div class="skeleton skeleton-trend"></div>
                <div class="stat-info-skeleton">
                    <div class="skeleton skeleton-number"></div>
                    <div class="skeleton skeleton-label"></div>
                </div>
            </div>
        }
        else
        {
            <div class="stat-card-top">
                <div class="stat-icon-wrapper blue">
                    <span class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                    </span>
                </div>
                <div class="stat-trend up">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                    <span>+@AppointmentsTodayCount today</span>
                </div>
            </div>
            <div class="stat-info">
                <div class="stat-number-wrapper">
                    <p class="stat-number">@TotalAppointmentsCount.ToString("N0")</p>
                </div>
                <h3>APPOINTMENTS</h3>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int VerifiedUsersCount { get; set; }
    [Parameter] public int UnverifiedUsersCount { get; set; }
    [Parameter] public int TotalIncidentsCount { get; set; }
    [Parameter] public int IncidentsTodayCount { get; set; }
    [Parameter] public int TotalAppointmentsCount { get; set; }
    [Parameter] public int AppointmentsTodayCount { get; set; }
    [Parameter] public bool IsLoading { get; set; }
}
