@page "/admin/app"
@layout AdminDashboardLayout
@implements IDisposable

@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using CBOS.Components.Shared
@using CBOS.Components.Services
@using CBOS.Components.Model

@inject NavigationManager Navigation
@inject ILogger<AdminApp> Logger
@inject AdminSupabase AdminSupabase
@inject IncidentManagementService IncidentService
@inject ProtectedSessionStorage ProtectedSessionStorage
@inject LayoutService LayoutService
@inject AppointmentTicketSupabase TicketService
@inject AdminCommunityManagerSupabase CommunityService
@inject AdminVerificationManagerSupabase VerificationService

@inject IJSRuntime JS

@rendermode InteractiveServer

@if (!_isAuthorized)
{
    <div class="auth-loading">
        <div class="spinner"></div>
        <p>Verifying session…</p>
    </div>
}
else
{
    <div class="content-wrapper">
                @if (ActiveFilter == NotifFilter.Home)
                {
                    <div class="welcome-section">
                        <div class="welcome-orb orb-1"></div>
                        <div class="welcome-orb orb-2"></div>
                        <div class="welcome-text-group">
                            <h1>Welcome back, Admin @adminFirstName.</h1>
                            <p>Here's what's happening in your Barangay today.</p>
                        </div>
                        <div class="welcome-actions">
                            <button class="quick-action-btn" @onclick="LoadDashboardData">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                                Refresh Data
                            </button>
                        </div>
                    </div>

                    <AdminStatCards 
                        TotalIncidentsCount="TotalIncidentsCount"
                        IncidentsTodayCount="IncidentsTodayCount"
                        TotalAppointmentsCount="TotalAppointmentsCount"
                        AppointmentsTodayCount="AppointmentsTodayCount"
                        VerifiedUsersCount="VerifiedUsersCount"
                        UnverifiedUsersCount="UnverifiedUsersCount"
                        IsLoading="_isLoading" />


                    <AdminUserGrowthChart 
                        @ref="userGrowthChartComponent"
                        TrendData="trendData"
                        ActiveTimeRange="@ActiveTimeRange"
                        IsLoading="_isLoading"
                        OnTimeRangeChanged="SetTimeRange"
                        ChartOptions="chartOptions" />


                    <div class="section-divider">
                        <h2 class="section-label">Overview</h2>
                        <span class="section-line"></span>
                    </div>

                    <AdminTrendCharts 
                        @ref="trendChartsComponent"
                        IncidentTrendData="incidentTrendData"
                        AppointmentTrendData="appTrendData"
                        IsLoading="_isLoading"
                        IncidentChartOptions="incidentLineChartOptions"
                        AppointmentChartOptions="appLineChartOptions" />
                    
                    <AdminStatusPieCharts 
                        @ref="statusPieChartsComponent"
                        VerificationStatusData="verificationStatusData"
                        PostStatusData="postStatusData"
                        IncidentStatusData="incidentStatuses"
                        IsLoading="_isLoading"
                        VerificationStatusPieOptions="verificationStatusPieOptions"
                        PostStatusPieOptions="postStatusPieOptions"
                        IncidentPieOptions="pieChartOptions" />

                    <div class="dashboard-grid-2">
                        <div class="dashboard-col">
<AdminDashboardTable 
    TableType="AdminDashboardTable.DashboardTableType.Verification"
    Title="User Verification"
    Headers="verificationHeaders"
    IsLoading="_isLoading"
    SkeletonRows="5"
    VerificationUsers="verificationUsers"
    OnViewAll="OnViewAllVerifications" />
                                <AdminDashboardTable 
                                    TableType="AdminDashboardTable.DashboardTableType.Incident"
                                    Title="Recent Incident Reports"
                                    Headers="incidentHeaders"
                                    IsLoading="_isLoading"
                                    SkeletonRows="5"
                                    IncidentReports="incidentReports"
                                    OnViewAll="OnViewAllIncidents" />
                        </div>
                        <div class="dashboard-col">
<AdminDashboardTable 
                                    TableType="AdminDashboardTable.DashboardTableType.CommunityPost"
                                    Title="Recent Community Posts"
                                    Headers="communityPostHeaders"
                                    IsLoading="_isLoading"
                                    SkeletonRows="5"
                                    CommunityPosts="communityPosts"
                                    OnViewAll="OnViewAllPosts" />
                                <AdminDashboardTable 
                                    TableType="AdminDashboardTable.DashboardTableType.Appointment"
                                    Title="Appointments"
                                    Headers="appointmentHeaders"
                                    IsLoading="_isLoading"
                                    SkeletonRows="5"
                                    Appointments="appointments"
                                    OnViewAll="OnViewAllAppointments" />
                        </div>
                    </div>
                }
                else
                {
                    <p class="placeholder-text">@FilterLabel View - Coming Soon</p>
                }
    </div>
}

