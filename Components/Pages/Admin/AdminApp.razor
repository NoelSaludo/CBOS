                Value = g.Sum(x => x.Count)
            })
            .ToList();

        _isLoading = false;
        StateHasChanged();
    }

    private async void HandleSidebarToggled()
    {
        // Smooth resizing by triggering multiple times during the transition
        const int totalDuration = 350;
        const int steps = 5;
        const int delayPerStep = totalDuration / steps;

        for (int i = 0; i < steps; i++)
        {
            await Task.Delay(delayPerStep);
            try
            {
                await JS.InvokeVoidAsync("eval", "window.dispatchEvent(new Event('resize'))");
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error dispatching resize event during transition step {Step}.", i);
            }
        }
        
        await RedrawCharts();
    }

    private async Task RedrawCharts()
    {
        try
        {
            var tasks = new List<Task>();
            if (userGrowthChartComponent != null) tasks.Add(userGrowthChartComponent.RenderAsync());
            if (trendChartsComponent != null) tasks.Add(trendChartsComponent.RenderAllAsync());
            if (statusPieChartsComponent != null) tasks.Add(statusPieChartsComponent.RenderAllAsync());

            if (tasks.Any())
            {
                await Task.WhenAll(tasks);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error redrawing charts after sidebar toggle.");
        }
    }

