    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var result = await ProtectedSessionStorage.GetAsync<string>("adminSessionKey");

            if (!result.Success || string.IsNullOrWhiteSpace(result.Value))
            {
                Logger.LogWarning("No adminSessionKey found in ProtectedSessionStorage.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            var isValid = await AdminSupabase.CheckSessionKey(result.Value);

            if (!isValid)
            {
                Logger.LogWarning("adminSessionKey exists but is invalid or expired.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            _isAuthorized = true;
            await LoadDashboardData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error validating admin session.");
            Navigation.NavigateTo("/admin/access-denied");
        }
    }

