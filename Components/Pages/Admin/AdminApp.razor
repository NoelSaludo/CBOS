@code {
    private bool _isAuthorized = false;

    private List<RegistrationData> trendData = new();
    private ApexChartOptions<RegistrationData> chartOptions = new();

    public class RegistrationData
    {
        public string Month { get; set; } = "";
        public int Count { get; set; }
    }
    public enum NotifFilter { Home, All, Appointment, Incident, Verification }
    private NotifFilter ActiveFilter = NotifFilter.Home;
    private int UnreadCount = 0;

    private string FilterLabel => ActiveFilter switch
    {
        NotifFilter.Home         => "General Analytics",
        NotifFilter.All          => "All Unread Notifications",
        NotifFilter.Appointment  => "Appointment Schedules",
        NotifFilter.Incident     => "Incident Reports",
        NotifFilter.Verification => "Verification Requests",
        _                        => string.Empty
    };

    protected override void OnInitialized()
    {
        trendData = new List<RegistrationData>
        {
            new RegistrationData { Month = "JAN", Count = 120 },
            new RegistrationData { Month = "FEB", Count = 230 },
            new RegistrationData { Month = "MAR", Count = 310 },
            new RegistrationData { Month = "APR", Count = 480 },
            new RegistrationData { Month = "MAY", Count = 550 },
            new RegistrationData { Month = "JUN", Count = 820 }
        };

        chartOptions = new ApexChartOptions<RegistrationData>
        {
            Chart = new Chart { Toolbar = new Toolbar { Show = false } },
            DataLabels = new DataLabels { Enabled = false },
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 4, Colors = new List<string> { "#001d44" } },
            Fill = new Fill { Type = new List<FillType> { FillType.Solid }, Colors = new List<string> { "#f3f4f5" }, Opacity = 1 },
            Xaxis = new XAxis { Labels = new XAxisLabels { Style = new AxisLabelStyle { FontSize = "10px", FontWeight = "700" } } },
            Yaxis = new List<YAxis> { new YAxis { Show = false } },
            Grid = new Grid { Show = false }
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var result = await ProtectedSessionStorage.GetAsync<string>("adminSessionKey");

            if (!result.Success || string.IsNullOrWhiteSpace(result.Value))
            {
                Logger.LogWarning("No adminSessionKey found in ProtectedSessionStorage.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            var isValid = await AdminSupabase.CheckSessionKey(result.Value);

            if (!isValid)
            {
                Logger.LogWarning("adminSessionKey exists but is invalid or expired.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            _isAuthorized = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error validating admin session.");
            Navigation.NavigateTo("/admin/access-denied");
        }
    }

    private void SetFilter(NotifFilter filter)
    {
        ActiveFilter = filter;
    }

    private async Task Logout()
    {
        try
        {
            var result = await ProtectedSessionStorage.GetAsync<string>("adminSessionKey");
            if (result.Success && !string.IsNullOrWhiteSpace(result.Value))
            {
                await AdminSupabase.DeleteSession(result.Value);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during logout.");
        }
        finally
        {
            await ProtectedSessionStorage.DeleteAsync("adminSessionKey");
            Navigation.NavigateTo("/Admin/Login");
        }
    }
}
