@page "/admin/app"
@layout AdminLayout

@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

@inject NavigationManager Navigation
@inject ILogger<AdminApp> Logger
@inject AdminSupabase AdminSupabase
@inject ProtectedSessionStorage ProtectedSessionStorage

@rendermode InteractiveServer

@if (!_isAuthorized)
{
    <div class="auth-loading">
        <div class="spinner"></div>
        <p>Verifying session…</p>
    </div>
}
else
{
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo-mark">CB</div>
                <div class="brand-text">
                    <span class="brand-title">CBOS</span>
                    <span class="brand-sub">Batangas Admin</span>
                </div>
            </div>

            <nav class="sidebar-nav">
                <button class="nav-item @(ActiveFilter == NotifFilter.All ? "active" : "")"
                        @onclick="() => SetFilter(NotifFilter.All)">
                    <span class="nav-icon">🔔</span>
                    <span>All Notifications</span>
                    @if (UnreadCount > 0)
                    {
                        <span class="badge">@UnreadCount</span>
                    }
                </button>
                <button class="nav-item @(ActiveFilter == NotifFilter.Appointment ? "active" : "")"
                        @onclick="() => SetFilter(NotifFilter.Appointment)">
                    <span class="nav-icon">📅</span>
                    <span>Appointment Schedules</span>
                </button>
                <button class="nav-item @(ActiveFilter == NotifFilter.Incident ? "active" : "")"
                        @onclick="() => SetFilter(NotifFilter.Incident)">
                    <span class="nav-icon">⚠️</span>
                    <span>Incident Reports</span>
                </button>
                <button class="nav-item @(ActiveFilter == NotifFilter.Verification ? "active" : "")"
                        @onclick="() => SetFilter(NotifFilter.Verification)">
                    <span class="nav-icon">✅</span>
                    <span>Verification Requests</span>
                </button>
            </nav>

            <div class="sidebar-footer">
                <button class="logout-btn" @onclick="Logout">
                    <span class="nav-icon">🚪</span>
                    <span>Logout</span>
                </button>
            </div>
        </aside>

        <!-- Main content -->
        <main class="main-content">
            <header class="topbar">
                <div class="topbar-title">
                    <h1>Admin Dashboard</h1>
                    <span class="topbar-subtitle">@FilterLabel</span>
                </div>
                <div class="topbar-actions">
                    <span class="admin-chip">Administrator</span>
                </div>
            </header>

            <section class="content-area">
                <p class="placeholder-text">Admin Dashboard</p>
            </section>
        </main>
    </div>
}

@code {
    private bool _isAuthorized = false;

    public enum NotifFilter { All, Appointment, Incident, Verification }
    private NotifFilter ActiveFilter = NotifFilter.All;
    private int UnreadCount = 0;

    private string FilterLabel => ActiveFilter switch
    {
        NotifFilter.All          => "All Unread Notifications",
        NotifFilter.Appointment  => "Appointment Schedules",
        NotifFilter.Incident     => "Incident Reports",
        NotifFilter.Verification => "Verification Requests",
        _                        => string.Empty
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var result = await ProtectedSessionStorage.GetAsync<string>("adminSessionKey");

            if (!result.Success || string.IsNullOrWhiteSpace(result.Value))
            {
                Logger.LogWarning("No adminSessionKey found in ProtectedSessionStorage.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            var isValid = await AdminSupabase.CheckSessionKey(result.Value);

            if (!isValid)
            {
                Logger.LogWarning("adminSessionKey exists but is invalid or expired.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            _isAuthorized = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error validating admin session.");
            Navigation.NavigateTo("/admin/access-denied");
        }
    }

    private void SetFilter(NotifFilter filter)
    {
        ActiveFilter = filter;
    }

    private async Task Logout()
    {
        try
        {
            var result = await ProtectedSessionStorage.GetAsync<string>("adminSessionKey");
            if (result.Success && !string.IsNullOrWhiteSpace(result.Value))
            {
                await AdminSupabase.DeleteSession(result.Value);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during logout.");
        }
        finally
        {
            await ProtectedSessionStorage.DeleteAsync("adminSessionKey");
            Navigation.NavigateTo("/Admin/Login");
        }
    }
}
