@page "/admin/app"
@layout AdminDashboardLayout

@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using CBOS.Components.Shared

@inject NavigationManager Navigation
@inject ILogger<AdminApp> Logger
@inject AdminSupabase AdminSupabase
@inject ProtectedSessionStorage ProtectedSessionStorage

@rendermode InteractiveServer

@if (!_isAuthorized)
{
    <div class="auth-loading">
        <div class="spinner"></div>
        <p>Verifying session…</p>
    </div>
}
else
{
    <div class="content-wrapper">
                @if (ActiveFilter == NotifFilter.Home)
                {
                    <div class="welcome-section">
                        <div class="welcome-orb orb-1"></div>
                        <div class="welcome-orb orb-2"></div>
                        <div class="welcome-text-group">
                            <p class="welcome-date">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
                            <h1>Welcome back, Official Name.</h1>
                            <p>Here's what's happening in your Barangay today.</p>
                        </div>
                        <div class="welcome-actions">
                            <button class="quick-action-btn">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                Download Report
                            </button>
                            <button class="quick-action-btn">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                                System Settings
                            </button>
                        </div>
                    </div>

                    <div class="analytics-grid">
                        <div class="stat-card">
                            <div class="stat-card-top">
                                <div class="stat-icon-wrapper green">
                                    <span class="stat-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                    </span>
                                </div>
                                <div class="stat-trend up">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                                    <span>+12%</span>
                                </div>
                            </div>
                            <div class="stat-info">
                                <div class="stat-number-wrapper">
                                    <p class="stat-number">1,024</p>
                                </div>
                                <h3>FULLY VERIFIED USERS</h3>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-card-top">
                                <div class="stat-icon-wrapper orange">
                                    <span class="stat-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="10"></circle>
                                            <polyline points="12 6 12 12 16 14"></polyline>
                                        </svg>
                                    </span>
                                </div>
                                <div class="stat-trend down">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline><polyline points="17 18 23 18 23 12"></polyline></svg>
                                    <span>-5%</span>
                                </div>
                            </div>
                            <div class="stat-info">
                                <div class="stat-number-wrapper">
                                    <p class="stat-number">45</p>
                                </div>
                                <h3>PARTIALLY UNVERIFIED</h3>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-card-top">
                                <div class="stat-icon-wrapper red">
                                    <span class="stat-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                            <line x1="12" y1="9" x2="12" y2="13"></line>
                                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                        </svg>
                                    </span>
                                </div>
                                <div class="stat-trend up">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                                    <span>+2 today</span>
                                </div>
                            </div>
                            <div class="stat-info">
                                <div class="stat-number-wrapper">
                                    <p class="stat-number">12</p>
                                </div>
                                <h3>INCIDENT REPORTS</h3>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-card-top">
                                <div class="stat-icon-wrapper blue">
                                    <span class="stat-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                            <line x1="16" y1="2" x2="16" y2="6"></line>
                                            <line x1="8" y1="2" x2="8" y2="6"></line>
                                            <line x1="3" y1="10" x2="21" y2="10"></line>
                                        </svg>
                                    </span>
                                </div>
                                <div class="stat-trend up">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                                    <span>+8 today</span>
                                </div>
                            </div>
                            <div class="stat-info">
                                <div class="stat-number-wrapper">
                                    <p class="stat-number">08</p>
                                </div>
                                <h3>APPOINTMENTS</h3>
                            </div>
                        </div>
                    </div>

                    <div class="analytics-chart-container">
                        <div class="architectural-card">
                            <div class="card-header-split">
                                <div class="chart-title-left">
                                    <h2 class="card-title">User Growth Analytics</h2>
                                    <p class="card-subtitle">@(ActiveTimeRange == "6M" ? "Resident registration trends over the last 6 months" : ActiveTimeRange == "1Y" ? "Resident registration trends over the last year" : "Overall resident registration trends")</p>
                                </div>
                                <div class="chart-actions">
                                    <div class="time-filter">
                                        <button class="filter-btn @(ActiveTimeRange == "6M" ? "active" : "")" @onclick='() => SetTimeRange("6M")'>6M</button>
                                        <button class="filter-btn @(ActiveTimeRange == "1Y" ? "active" : "")" @onclick='() => SetTimeRange("1Y")'>1Y</button>
                                        <button class="filter-btn @(ActiveTimeRange == "ALL" ? "active" : "")" @onclick='() => SetTimeRange("ALL")'>ALL</button>
                                    </div>
                                    <span class="stat-badge live">LIVE</span>
                                </div>
                            </div>
                            <div class="chart-placeholder">
                                @if (_isLoading)
                                {
                                    <div class="skeleton skeleton-chart"></div>
                                }
                                else if (trendData == null || !trendData.Any())
                                {
                                    <div class="empty-state">
                                        <div class="empty-state-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <line x1="18" y1="20" x2="18" y2="10"></line>
                                                <line x1="12" y1="20" x2="12" y2="4"></line>
                                                <line x1="6" y1="20" x2="6" y2="14"></line>
                                            </svg>
                                        </div>
                                        <p class="empty-state-text">No registration data available for this period.</p>
                                    </div>
                                }
                                else
                                {
                                    <ApexChart TItem="RegistrationData"
                                               Height="@("250")"
                                               Options="chartOptions">
                                        <ApexPointSeries TItem="RegistrationData"
                                                         Items="trendData"
                                                         Name="Registrations"
                                                         SeriesType="SeriesType.Area"
                                                         XValue="@(e => e.Month)"
                                                         YValue="@(e => e.Count)" />
                                    </ApexChart>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="section-divider">
                        <h2 class="section-label">Overview</h2>
                        <span class="section-line"></span>
                    </div>

                    <div class="dashboard-split">
                        <!-- Left Column (Incident Reports) -->
                        <div class="dashboard-col-left">
                            <div class="architectural-card list-card">
                                <div class="card-header-split">
                                    <h2 class="card-title">User Verification</h2>
                                    <a href="#" class="card-link">VIEW ALL</a>
                                </div>
                                <div class="table-container">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>NAME</th>
                                                <th>DATE REGISTERED</th>
                                                <th>STATUS</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (_isLoading)
                                            {
                                                @for (int i = 0; i < 4; i++)
                                                {
                                                    <tr>
                                                        <td><div class="skeleton skeleton-text" style="width: 70px;"></div></td>
                                                        <td><div class="skeleton skeleton-text"></div></td>
                                                        <td><div class="skeleton skeleton-text" style="width: 80px;"></div></td>
                                                        <td><div class="skeleton skeleton-text" style="width: 90px;"></div></td>
                                                    </tr>
                                                }
                                            }
                                            else if (verificationUsers == null || !verificationUsers.Any())
                                            {
                                                <tr>
                                                    <td colspan="4">
                                                        <div class="empty-state">
                                                            <div class="empty-state-icon">
                                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                                                    <circle cx="12" cy="7" r="4"></circle>
                                                                </svg>
                                                            </div>
                                                            <p class="empty-state-text">No pending verifications found.</p>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                @foreach (var user in verificationUsers)
                                                {
                                                    <tr>
                                                        <td class="id-cell">@user.Id</td>
                                                        <td class="bold-cell">
                                                            <div class="user-avatar-group">
                                                                <div class="avatar-circle">@user.Name[0]</div>
                                                                <div class="name-details">
                                                                    <span>@user.Name</span>
                                                                    <span class="sub-text">Resident</span>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="light-cell">@user.DateRegistered</td>
                                                        <td><span class="data-chip @user.StatusClass">@user.Status</span></td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>

                            <div class="architectural-card list-card">
                                <div class="card-header-split">
                                    <h2 class="card-title">Recent Incident Reports</h2>
                                    <a href="#" class="card-link">VIEW ALL</a>
                                </div>
                                <div class="table-container">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>COMPLAINANT</th>
                                                <th>TITLE</th>
                                                <th>CATEGORY</th>
                                                <th>DATE</th>
                                                <th>STATUS</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (_isLoading)
                                            {
                                                @for (int i = 0; i < 4; i++)
                                                {
                                                    <tr>
                                                        <td><div class="skeleton skeleton-text" style="width: 70px;"></div></td>
                                                        <td><div class="skeleton skeleton-text"></div></td>
                                                        <td><div class="skeleton skeleton-text"></div></td>
                                                        <td><div class="skeleton skeleton-text" style="width: 60px;"></div></td>
                                                        <td><div class="skeleton skeleton-text" style="width: 80px;"></div></td>
                                                        <td><div class="skeleton skeleton-text" style="width: 70px;"></div></td>
                                                    </tr>
                                                }
                                            }
                                            else if (incidentReports == null || !incidentReports.Any())
                                            {
                                                <tr>
                                                    <td colspan="6">
                                                        <div class="empty-state">
                                                            <div class="empty-state-icon">
                                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                                                    <line x1="12" y1="9" x2="12" y2="13"></line>
                                                                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                                                </svg>
                                                            </div>
                                                            <p class="empty-state-text">No incident reports recorded.</p>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                @foreach (var report in incidentReports)
                                                {
                                                    <tr>
                                                        <td class="id-cell">@report.Id</td>
                                                        <td class="bold-cell">@report.Complainant</td>
                                                        <td class="light-cell">@report.Title</td>
                                                        <td><span class="data-chip @report.CategoryClass">@report.Category</span></td>
                                                        <td class="light-cell">@report.Date</td>
                                                        <td><span class="data-chip @report.StatusClass">@report.Status</span></td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                            
                            <div class="architectural-card list-card">
                                <div class="card-header-split">
                                    <h2 class="card-title">Recent Community Posts</h2>
                                    <a href="#" class="card-link">VIEW ALL</a>
                                </div>
                                <div class="table-container">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>AUTHOR</th>
                                                <th>TOPIC</th>
                                                <th>DATE</th>
                                                <th>STATUS</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (_isLoading)
                                            {
                                                @for (int i = 0; i < 3; i++)
                                                {
                                                    <tr>
                                                        <td><div class="skeleton skeleton-text" style="width: 70px;"></div></td>
                                                        <td><div class="skeleton skeleton-text"></div></td>
                                                        <td><div class="skeleton skeleton-text"></div></td>
                                                        <td><div class="skeleton skeleton-text" style="width: 80px;"></div></td>
                                                        <td><div class="skeleton skeleton-text" style="width: 70px;"></div></td>
                                                    </tr>
                                                }
                                            }
                                            else if (communityPosts == null || !communityPosts.Any())
                                            {
                                                <tr>
                                                    <td colspan="5">
                                                        <div class="empty-state">
                                                            <div class="empty-state-icon">
                                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                                    <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                                                </svg>
                                                            </div>
                                                            <p class="empty-state-text">No community posts found.</p>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                @foreach (var post in communityPosts)
                                                {
                                                    <tr>
                                                        <td class="id-cell">@post.Id</td>
                                                        <td class="bold-cell">@post.Author</td>
                                                        <td class="light-cell">@post.Topic</td>
                                                        <td class="light-cell">@post.Date</td>
                                                        <td><span class="data-chip @post.StatusClass">@post.Status</span></td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>

                        <!-- Right Column (Appointments & System Update) -->
                        <div class="dashboard-col-right">
                            <div class="architectural-card appointments-card">
                                <div class="card-header-split">
                                    <h2 class="card-title">Appointments</h2>
                                    <a href="#" class="card-link">VIEW ALL</a>
                                </div>
                                <div class="appointments-list">
                                    @if (_isLoading)
                                    {
                                        @for (int i = 0; i < 4; i++)
                                        {
                                            <div class="appointment-item">
                                                <div class="app-header-row">
                                                    <div class="skeleton skeleton-text" style="width: 70px;"></div>
                                                    <div class="skeleton skeleton-text" style="width: 60px;"></div>
                                                </div>
                                                <div class="app-body">
                                                    <div class="skeleton skeleton-text" style="margin-bottom: 0.5rem;"></div>
                                                    <div class="skeleton skeleton-text" style="width: 80%;"></div>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else if (appointments == null || !appointments.Any())
                                    {
                                        <div class="empty-state">
                                            <div class="empty-state-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                                </svg>
                                            </div>
                                            <p class="empty-state-text">No scheduled appointments today.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        @foreach (var app in appointments)
                                        {
                                            <div class="appointment-item @app.StatusClass">
                                                <div class="app-header-row">
                                                    <span class="app-id">@app.Id</span>
                                                    <span class="data-chip @app.StatusClass">@app.Status</span>
                                                </div>
                                                <div class="app-body">
                                                    <div class="app-name">@app.Name</div>
                                                    <div class="app-meta">
                                                        <span class="app-category">@app.Category</span>
                                                        <span class="app-service">@app.Service</span>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <p class="placeholder-text">@FilterLabel View - Coming Soon</p>
                }
    </div>
}

@code {
    private bool _isAuthorized = false;
    private bool _isLoading = true;

    private List<RegistrationData> trendData = new();
    private List<VerificationUser> verificationUsers = new();
    private List<IncidentReport> incidentReports = new();
    private List<CommunityPost> communityPosts = new();
    private List<Appointment> appointments = new();

    private ApexChartOptions<RegistrationData> chartOptions = new();

    public class RegistrationData
    {
        public string Month { get; set; } = "";
        public int Count { get; set; }
    }

    public class VerificationUser
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string DateRegistered { get; set; } = "";
        public string Status { get; set; } = "";
        public string StatusClass { get; set; } = "";
    }

    public class IncidentReport
    {
        public string Id { get; set; } = "";
        public string Complainant { get; set; } = "";
        public string Title { get; set; } = "";
        public string Category { get; set; } = "";
        public string CategoryClass { get; set; } = "";
        public string Date { get; set; } = "";
        public string Status { get; set; } = "";
        public string StatusClass { get; set; } = "";
    }

    public class CommunityPost
    {
        public string Id { get; set; } = "";
        public string Author { get; set; } = "";
        public string Topic { get; set; } = "";
        public string Date { get; set; } = "";
        public string Status { get; set; } = "";
        public string StatusClass { get; set; } = "";
    }

    public class Appointment
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string Category { get; set; } = "";
        public string Service { get; set; } = "";
        public string Status { get; set; } = "";
        public string StatusClass { get; set; } = "";
    }

    public enum NotifFilter { Home, All, Appointment, Incident, Verification }
    private NotifFilter ActiveFilter = NotifFilter.Home;
    private int UnreadCount = 0;
    private string ActiveTimeRange = "6M";

    private string FilterLabel => ActiveFilter switch
    {
        NotifFilter.Home         => "General Analytics",
        NotifFilter.All          => "All Unread Notifications",
        NotifFilter.Appointment  => "Appointment Schedules",
        NotifFilter.Incident     => "Incident Reports",
        NotifFilter.Verification => "Verification Requests",
        _                        => string.Empty
    };

    protected override void OnInitialized()
    {
        chartOptions = new ApexChartOptions<RegistrationData>
        {
            Chart = new Chart 
            { 
                Toolbar = new Toolbar { Show = false },
                Animations = new Animations { Enabled = true, Easing = Easing.Easeinout, Speed = 800 }
            },
            DataLabels = new DataLabels { Enabled = false },
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 3, Colors = new List<string> { "#3b82f6" } },
            Fill = new Fill 
            { 
                Type = new List<FillType> { FillType.Gradient },
                Gradient = new FillGradient
                {
                    ShadeIntensity = 1,
                    OpacityFrom = 0.45,
                    OpacityTo = 0.05,
                    Stops = new List<double> { 0, 100 }
                }
            },
