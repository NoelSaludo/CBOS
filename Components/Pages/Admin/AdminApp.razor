    private async Task SetTimeRange(string range)
    {
        ActiveTimeRange = range;
        _isLoading = true;
        StateHasChanged();
        
        await Task.Delay(500); 

        // User Growth is now driven by RefreshVerificationDataAsync which handles all ranges
        await RefreshVerificationDataAsync(redrawChart: false, clearOnFailure: false);

        incidentTrendData = BuildIncidentTrends(_allIncidentData, ActiveTimeRange);
        
        // Refresh appointment data for the new time range
        await RefreshAppointmentDataAsync(redrawChart: false, clearOnFailure: false);

        if (trendChartsComponent != null)
        {
            _ = trendChartsComponent.RenderAllAsync();
        }

        _isLoading = false;
        StateHasChanged();
    }


