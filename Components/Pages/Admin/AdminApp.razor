    private static List<CategoryData> BuildIncidentStatuses(IEnumerable<IncidentReportDto> incidentData)
    {
        var counts = incidentData
            .GroupBy(report => NormalizeIncidentStatus(report.Status))
            .ToDictionary(group => group.Key, group => group.Count());

        var orderedStatuses = new[] { "PENDING", "RESOLVED", "REJECTED" };

        var statuses = orderedStatuses
            .Select(status => new CategoryData
            {
                Name = status,
                Value = counts.TryGetValue(status, out var count) ? count : 0
            })
            .ToList();

        return statuses;
    }

    private static List<IncidentTrendData> BuildIncidentTrends(IEnumerable<IncidentReportDto> incidentData, string timeRange)
    {
        var categories = new[] { "EMERGENCY", "COMPLAINT", "SUGGESTION", "OTHER" };
        var result = new List<IncidentTrendData>();

        if (timeRange == "ALL")
        {
            var years = incidentData.Select(d => d.Date.Year).Distinct().OrderBy(y => y).ToList();
            if (!years.Any()) years = new List<int> { DateTime.UtcNow.Year }; // fallback

            foreach (var category in categories)
            {
                foreach (var year in years)
                {
                    var count = incidentData.Count(d => d.Category == category && d.Date.Year == year);
                    result.Add(new IncidentTrendData
                    {
                        Month = year.ToString(),
                        Category = category,
                        Count = count
                    });
                }
            }
        }
        else
        {
            var monthsToGenerate = timeRange == "1Y" ? 12 : 6;
            var endDate = DateTime.UtcNow;
            var months = new List<DateTime>();
            for (int i = 0; i < monthsToGenerate; i++)
            {
                months.Add(endDate.AddMonths(- (monthsToGenerate - 1 - i)));
            }

            foreach (var category in categories)
            {
                foreach (var monthDate in months)
                {
                    var monthStr = monthDate.ToString("MMM").ToUpperInvariant();
                    var count = incidentData.Count(d => d.Category == category && d.Date.Year == monthDate.Year && d.Date.Month == monthDate.Month);
                    
                    result.Add(new IncidentTrendData 
                    {
                        Month = monthStr,
                        Category = category,
                        Count = count
                    });
                }
            }
        }

        return result;
    }

    private static List<AppointmentTrendData> BuildAppointmentTrends(IEnumerable<AppointmentTicketModel> appointmentData, string timeRange)
    {
        var categories = new[] 
        { 
            "Document Requests", 
            "Complaint & Mediation", 
            "Permits & Clearances", 
            "Community Programs", 
            "Assistance Services" 
        };
        var result = new List<AppointmentTrendData>();

        if (timeRange == "ALL")
        {
            var years = appointmentData.Select(d => d.ScheduledDate.Year).Distinct().OrderBy(y => y).ToList();
            if (!years.Any()) years = new List<int> { DateTime.UtcNow.Year };

            foreach (var category in categories)
            {
                foreach (var year in years)
                {
                    var count = appointmentData.Count(d => (d.AppointmentType?.StartsWith(category, StringComparison.OrdinalIgnoreCase) ?? false) && d.ScheduledDate.Year == year);
                    result.Add(new AppointmentTrendData
                    {
                        Month = year.ToString(),
                        Category = category.ToUpperInvariant(),
                        Count = count
                    });
                }
            }
        }
        else
        {
            var monthsToGenerate = timeRange == "1Y" ? 12 : 6;
            var endDate = DateTime.UtcNow;
            var months = new List<DateTime>();
            for (int i = 0; i < monthsToGenerate; i++)
            {
                months.Add(endDate.AddMonths(- (monthsToGenerate - 1 - i)));
            }

            foreach (var category in categories)
            {
                foreach (var monthDate in months)
                {
                    var monthStr = monthDate.ToString("MMM").ToUpperInvariant();
                    var count = appointmentData.Count(d => (d.AppointmentType?.StartsWith(category, StringComparison.OrdinalIgnoreCase) ?? false) && d.ScheduledDate.Year == monthDate.Year && d.ScheduledDate.Month == monthDate.Month);
                    
                    result.Add(new AppointmentTrendData 
                    {
                        Month = monthStr,
                        Category = category.ToUpperInvariant(),
                        Count = count
                    });
                }
            }
        }

        return result;
    }


    private static string NormalizeIncidentStatus(string status)

    {
        var normalizedStatus = status?.Trim().ToUpperInvariant() ?? string.Empty;

        return normalizedStatus switch
        {
            "PENDING" => "PENDING",
            "RESOLVED" => "RESOLVED",
            "REJECTED" => "REJECTED",
            _ => normalizedStatus
        };
    }

