    private async Task RefreshAppointmentDataAsync(bool redrawChart, bool clearOnFailure)
    {
        try
        {
            var appointmentData = await TicketService.GetAppointmentBoardAsync();
            
            TotalAppointmentsCount = appointmentData.Count;
            AppointmentsTodayCount = appointmentData.Count(a => a.ScheduledDate.Date == DateTime.Today);

            appointments = appointmentData
                .OrderByDescending(a => a.ScheduledDate)
                .Take(5)
                .Select(app => new Appointment
                {
                    Id = $"#TKT-{app.TicketId}",
                    Name = string.IsNullOrWhiteSpace(app.FullName) ? "Unknown" : app.FullName,
                    Category = string.IsNullOrWhiteSpace(app.AppointmentType) ? "General" : app.AppointmentType,
                    Service = app.Description.Length > 30 ? app.Description.Substring(0, 30) + "..." : app.Description,
                    Status = app.Status.ToUpperInvariant(),
                    StatusClass = GetAppointmentStatusClass(app.Status)
                })
                .ToList();


            appTrendData = BuildAppointmentTrends(appointmentData, ActiveTimeRange);

            StateHasChanged();

            if (redrawChart && trendChartsComponent != null)
            {
                await trendChartsComponent.RenderAllAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to refresh appointment dashboard data.");

            if (clearOnFailure)
            {
                appointments = new List<Appointment>();
                appTrendData = new List<AppointmentTrendData>();
                StateHasChanged();
            }
        }
    }

    private async Task RefreshIncidentDataAsync(bool redrawChart, bool clearOnFailure)

    {
        try
        {
            var incidentData = await IncidentService.GetIncidentReportsAsync();
            _allIncidentData = incidentData;
            
            TotalIncidentsCount = _allIncidentData.Count;
            IncidentsTodayCount = _allIncidentData.Count(d => d.Date.Date == DateTime.Today);

            incidentReports = incidentData
                .OrderByDescending(report => report.Date)
                .Take(5)
                .Select(report => new IncidentReport
                {
                    Id = report.FormattedId,
                    Complainant = string.IsNullOrWhiteSpace(report.Complainant) ? "Unknown" : report.Complainant,
                    Title = string.IsNullOrWhiteSpace(report.Title) ? "No Title" : report.Title,
                    Category = string.IsNullOrWhiteSpace(report.Category) ? "OTHER" : report.Category,
                    CategoryClass = GetIncidentCategoryClass(report.Category),
                    Date = report.Date.ToString("MMM dd, yyyy"),
                    Status = report.Status,
                    StatusClass = GetIncidentStatusClass(report.Status)
                })
                .ToList();

            incidentStatuses = BuildIncidentStatuses(incidentData);
            incidentTrendData = BuildIncidentTrends(_allIncidentData, ActiveTimeRange);

            var statusColors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
            {
                { "PENDING", "#f59e0b" },
                { "RESOLVED", "#10b981" },
                { "REJECTED", "#ef4444" }
            };
            
            if (incidentStatuses.Any())
            {
                pieChartOptions.Colors = incidentStatuses
                    .Select(s => statusColors.TryGetValue(s.Name, out var c) ? c : "#64748b")
                    .ToList();
            }

            StateHasChanged();

            if (redrawChart && trendChartsComponent != null)
            {
                await trendChartsComponent.RenderAllAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to refresh incident dashboard data.");

            if (clearOnFailure)
            {
                _allIncidentData = new List<IncidentReportDto>();
                incidentReports = new List<IncidentReport>();
                incidentStatuses = new List<CategoryData>();
                incidentTrendData = new List<IncidentTrendData>();
                StateHasChanged();
            }
        }
    }

    private async Task RefreshCommunityPostDataAsync(bool redrawChart, bool clearOnFailure)
    {
        try
        {
            var postData = await CommunityService.GetAllCommunityPostTicketsAsync();
            
            communityPosts = postData
                .OrderByDescending(p => p.CreatedAt)
                .Take(5)
                .Select(p => new CommunityPost
                {
                    Id = $"#PST-{p.TicketId}",
                    Author = string.IsNullOrWhiteSpace(p.Author) ? "Unknown" : p.Author,
                    Topic = string.IsNullOrWhiteSpace(p.Title) ? "Untitled" : p.Title,
                    Date = p.CreatedAt.ToString("MMM dd, yyyy"),
                    Status = p.Status.ToUpperInvariant(),
                    StatusClass = GetPostStatusClass(p.Status)
                })
                .ToList();

            postStatusData = BuildPostStatuses(postData);

            var statusColors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
            {
                { "PENDING", "#f59e0b" },
                { "APPROVED", "#10b981" },
                { "REJECTED", "#ef4444" }
            };
            
            if (postStatusData.Any())
            {
                postStatusPieOptions.Colors = postStatusData
                    .Select(s => statusColors.TryGetValue(s.Name, out var c) ? c : "#64748b")
                    .ToList();
            }

            StateHasChanged();

            if (redrawChart && statusPieChartsComponent != null)
            {
                await statusPieChartsComponent.RenderAllAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to refresh community post dashboard data.");

            if (clearOnFailure)
            {
                communityPosts = new List<CommunityPost>();
                postStatusData = new List<CategoryData>();
                StateHasChanged();
            }
        }
    }

    private async Task LoadDashboardData()
    {
        _isLoading = true;
        StateHasChanged();

        // Simulate API delay
        await Task.Delay(1500);

        await RefreshIncidentDataAsync(redrawChart: false, clearOnFailure: true);
        await RefreshAppointmentDataAsync(redrawChart: false, clearOnFailure: true);
        await RefreshCommunityPostDataAsync(redrawChart: false, clearOnFailure: true);
        await RefreshVerificationDataAsync(redrawChart: false, clearOnFailure: true);

        // verificationUsers and verificationStatusData are now populated in RefreshVerificationDataAsync

        _isLoading = false;
        StateHasChanged();
    }

    private async void HandleSidebarToggled()
    {
        // Smooth resizing by triggering multiple times during the transition
        const int totalDuration = 350;
        const int steps = 5;
        const int delayPerStep = totalDuration / steps;

        for (int i = 0; i < steps; i++)
        {
            await Task.Delay(delayPerStep);
            try
            {
                await JS.InvokeVoidAsync("eval", "window.dispatchEvent(new Event('resize'))");
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error dispatching resize event during transition step {Step}.", i);
            }
        }
        
        await RedrawCharts();
    }

    private async Task RedrawCharts()
    {
        try
        {
            var tasks = new List<Task>();
            if (userGrowthChartComponent != null) tasks.Add(userGrowthChartComponent.RenderAsync());
            if (trendChartsComponent != null) tasks.Add(trendChartsComponent.RenderAllAsync());
            if (statusPieChartsComponent != null) tasks.Add(statusPieChartsComponent.RenderAllAsync());

            if (tasks.Any())
            {
                await Task.WhenAll(tasks);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error redrawing charts after sidebar toggle.");
        }
    }

    public void Dispose()
    {
        LayoutService.OnSidebarToggled -= HandleSidebarToggled;
        IncidentService.OnIncidentsChanged -= HandleIncidentsChanged;
        TicketService.OnAppointmentsChanged -= HandleAppointmentsChanged;
        CommunityService.OnCommunityPostsChanged -= HandleCommunityPostsChanged;
        VerificationService.OnVerificationChanged -= HandleVerificationChanged;
    }


    private async void HandleIncidentsChanged()
    {
        try
        {
            await InvokeAsync(() => RefreshIncidentDataAsync(redrawChart: true, clearOnFailure: false));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error refreshing incident dashboard data after an incident update.");
        }
    }

    private async void HandleAppointmentsChanged()
    {
        try
        {
            await InvokeAsync(() => RefreshAppointmentDataAsync(redrawChart: true, clearOnFailure: false));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error refreshing appointment dashboard data after an appointment update.");
        }
    }

    private async void HandleCommunityPostsChanged()
    {
        try
        {
            await InvokeAsync(() => RefreshCommunityPostDataAsync(redrawChart: true, clearOnFailure: false));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error refreshing community post dashboard data after a post update.");
        }
    }

    private async void HandleVerificationChanged()
    {
        try
        {
            await InvokeAsync(() => RefreshVerificationDataAsync(redrawChart: true, clearOnFailure: false));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error refreshing verification dashboard data after a verification update.");
        }
    }

    private async Task RefreshVerificationDataAsync(bool redrawChart, bool clearOnFailure)
    {
        try
        {
            var ticketData = await VerificationService.GetVerificationTicketsAsync();
            
            verificationUsers = ticketData
                .OrderByDescending(t => t.CreatedDate)
                .Take(5)
                .Select(t => new VerificationUser
                {
                    Id = $"#USR-{t.UserId}",
                    Name = string.IsNullOrWhiteSpace(t.UserFullName) ? "Unknown" : t.UserFullName,
                    DateRegistered = t.CreatedDate.ToString("MMM dd, yyyy"),
                    Status = (t.Status ?? "Pending").ToUpperInvariant(),
                    StatusClass = GetVerificationStatusClass(t.Status)
                })
                .ToList();

            verificationStatusData = BuildVerificationStatuses(ticketData);

            VerifiedUsersCount = ticketData.Count(t => string.Equals(t.Status, "Approved", StringComparison.OrdinalIgnoreCase));
            UnverifiedUsersCount = ticketData.Count(t => !string.Equals(t.Status, "Approved", StringComparison.OrdinalIgnoreCase));

            var statusColors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
            {
                { "APPROVED", "#10b981" },
                { "PENDING", "#f59e0b" },
                { "REJECTED", "#ef4444" }
            };
            
            if (verificationStatusData.Any())
            {
                verificationStatusPieOptions.Colors = verificationStatusData
                    .Select(s => statusColors.TryGetValue(s.Name, out var c) ? c : "#64748b")
                    .ToList();
            }

            trendData = BuildUserGrowthTrends(ticketData, ActiveTimeRange);

            StateHasChanged();

            if (redrawChart && statusPieChartsComponent != null)
            {
                await statusPieChartsComponent.RenderAllAsync();
            }

            if (redrawChart && userGrowthChartComponent != null)
            {
                await userGrowthChartComponent.RenderAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to refresh verification dashboard data.");

            if (clearOnFailure)
            {
                verificationUsers = new List<VerificationUser>();
                verificationStatusData = new List<CategoryData>();
                StateHasChanged();
            }
        }
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var result = await ProtectedSessionStorage.GetAsync<string>("adminSessionKey");

            if (!result.Success || string.IsNullOrWhiteSpace(result.Value))
            {
                Logger.LogWarning("No adminSessionKey found in ProtectedSessionStorage.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            var isValid = await AdminSupabase.CheckSessionKey(result.Value);

            if (!isValid)
            {
                Logger.LogWarning("adminSessionKey exists but is invalid or expired.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            var admin = await AdminSupabase.GetAdminBySessionKey(result.Value);
            if (admin != null && !string.IsNullOrWhiteSpace(admin.FirstName))
            {
                adminFirstName = admin.FirstName;
            }

            _isAuthorized = true;
            await LoadDashboardData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error validating admin session.");
            Navigation.NavigateTo("/admin/access-denied");
        }
    }

