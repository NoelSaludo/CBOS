            foreach (var year in years)
            {
                var yearTickets = ticketData.Where(d => d.CreatedDate.Year == year).ToList();
                result.Add(new RegistrationData
                {
                    Month = year.ToString(),
                    AllCount = yearTickets.Count,
                    VerifiedCount = yearTickets.Count(t => string.Equals(t.Status, "Approved", StringComparison.OrdinalIgnoreCase)),
