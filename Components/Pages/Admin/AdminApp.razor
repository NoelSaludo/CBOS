@page "/admin/app"
@layout AdminDashboardLayout
@implements IDisposable

@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using CBOS.Components.Shared
@using CBOS.Components.Services

@inject NavigationManager Navigation
@inject ILogger<AdminApp> Logger
@inject AdminSupabase AdminSupabase
@inject IncidentManagementService IncidentService
@inject ProtectedSessionStorage ProtectedSessionStorage
@inject LayoutService LayoutService
@inject IJSRuntime JS

@rendermode InteractiveServer

@if (!_isAuthorized)
{
    <div class="auth-loading">
        <div class="spinner"></div>
        <p>Verifying session…</p>
    </div>
}
else
{
    <div class="content-wrapper">
                @if (ActiveFilter == NotifFilter.Home)
                {
                    <div class="welcome-section">
                        <div class="welcome-orb orb-1"></div>
                        <div class="welcome-orb orb-2"></div>
                        <div class="welcome-text-group">
                            <h1>Welcome back, Admin @adminFirstName.</h1>
                            <p>Here's what's happening in your Barangay today.</p>
                        </div>
                        <div class="welcome-actions">
                            <button class="quick-action-btn">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                Download Report
                            </button>
                            <button class="quick-action-btn">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                                System Settings
                            </button>
                        </div>
                    </div>

                    <div class="analytics-grid">
                        <div class="stat-card">
                            <div class="stat-card-top">
                                <div class="stat-icon-wrapper green">
                                    <span class="stat-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                    </span>
                                </div>
                                <div class="stat-trend up">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                                    <span>+12%</span>
                                </div>
                            </div>
                            <div class="stat-info">
                                <div class="stat-number-wrapper">
                                    <p class="stat-number">1,024</p>
                                </div>
                                <h3>FULLY VERIFIED USERS</h3>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-card-top">
                                <div class="stat-icon-wrapper orange">
                                    <span class="stat-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="10"></circle>
                                            <polyline points="12 6 12 12 16 14"></polyline>
                                        </svg>
                                    </span>
                                </div>
                                <div class="stat-trend down">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline><polyline points="17 18 23 18 23 12"></polyline></svg>
                                    <span>-5%</span>
                                </div>
                            </div>
                            <div class="stat-info">
                                <div class="stat-number-wrapper">
                                    <p class="stat-number">45</p>
                                </div>
                                <h3>PARTIALLY UNVERIFIED</h3>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-card-top">
                                <div class="stat-icon-wrapper red">
                                    <span class="stat-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                            <line x1="12" y1="9" x2="12" y2="13"></line>
                                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                        </svg>
                                    </span>
                                </div>
                                <div class="stat-trend up">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                                    <span>+@IncidentsTodayCount today</span>
                                </div>
                            </div>
                            <div class="stat-info">
                                <div class="stat-number-wrapper">
                                    <p class="stat-number">@TotalIncidentsCount</p>
                                </div>
                                <h3>INCIDENT REPORTS</h3>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-card-top">
                                <div class="stat-icon-wrapper blue">
                                    <span class="stat-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                            <line x1="16" y1="2" x2="16" y2="6"></line>
                                            <line x1="8" y1="2" x2="8" y2="6"></line>
                                            <line x1="3" y1="10" x2="21" y2="10"></line>
                                        </svg>
                                    </span>
                                </div>
                                <div class="stat-trend up">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                                    <span>+8 today</span>
                                </div>
                            </div>
                            <div class="stat-info">
                                <div class="stat-number-wrapper">
                                    <p class="stat-number">08</p>
                                </div>
                                <h3>APPOINTMENTS</h3>
                            </div>
                        </div>
                    </div>

                    <div class="analytics-chart-container">
                        <div class="architectural-card">
                            <div class="card-header-split">
                                <div class="chart-title-left">
                                    <h2 class="card-title">User Growth Analytics</h2>
                                    <p class="card-subtitle">@(ActiveTimeRange == "6M" ? "Resident registration trends over the last 6 months" : ActiveTimeRange == "1Y" ? "Resident registration trends over the last year" : "Overall resident registration trends")</p>
                                </div>
                                <div class="chart-actions">
                                    <div class="time-filter">
                                        <button class="filter-btn @(ActiveTimeRange == "6M" ? "active" : "")" @onclick='() => SetTimeRange("6M")'>6M</button>
                                        <button class="filter-btn @(ActiveTimeRange == "1Y" ? "active" : "")" @onclick='() => SetTimeRange("1Y")'>1Y</button>
                                        <button class="filter-btn @(ActiveTimeRange == "ALL" ? "active" : "")" @onclick='() => SetTimeRange("ALL")'>ALL</button>
                                    </div>
                                    <span class="stat-badge live">LIVE</span>
                                </div>
                            </div>
                            <div class="chart-placeholder">
                                @if (_isLoading)
                                {
                                    <div class="skeleton skeleton-chart"></div>
                                }
                                else if (trendData == null || !trendData.Any())
                                {
                                    <div class="empty-state">
                                        <div class="empty-state-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <line x1="18" y1="20" x2="18" y2="10"></line>
                                                <line x1="12" y1="20" x2="12" y2="4"></line>
                                                <line x1="6" y1="20" x2="6" y2="14"></line>
                                            </svg>
                                        </div>
                                        <p class="empty-state-text">No registration data available for this period.</p>
                                    </div>
                                }
                                else
                                {
                                    <ApexChart TItem="RegistrationData"
                                               @ref="registrationChart"
                                               Height="@("250")"
                                               Options="chartOptions">
                                        <ApexPointSeries TItem="RegistrationData"
                                                         Items="trendData"
                                                         Name="Registrations"
                                                         SeriesType="SeriesType.Area"
                                                         XValue="@(e => e.Month)"
                                                         YValue="@(e => e.Count)" />
                                    </ApexChart>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="section-divider">
                        <h2 class="section-label">Overview</h2>
                        <span class="section-line"></span>
                    </div>

                                        <div class="dashboard-grid-3">
<div class="architectural-card line-chart-card">
                                <div class="card-header-split">
                                    <h2 class="card-title">User Verification Trends</h2>
                                </div>
                                <div class="chart-placeholder">
                                    @if (_isLoading)
                                    {
                                        <div class="skeleton skeleton-chart"></div>
                                    }
                                    else if (verificationTrendData == null || !verificationTrendData.Any())
                                    {
                                        <div class="empty-state">
                                            <p class="empty-state-text">No verification trend data available.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <ApexChart TItem="UserVerificationTrendData"
                                                   @ref="verificationChart"
                                                   Height="@("250")"
                                                   Options="verificationChartOptions">
                                            <ApexPointSeries TItem="UserVerificationTrendData"
                                                             Items='verificationTrendData.Where(x => x.Status == "Verified").ToList()'
                                                             Name="Fully Verified"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                            <ApexPointSeries TItem="UserVerificationTrendData"
                                                             Items='verificationTrendData.Where(x => x.Status == "Partial").ToList()'
                                                             Name="Partially Verified"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                        </ApexChart>
                                    }
                                </div>
                            </div>
<div class="architectural-card line-chart-card">
                                <div class="card-header-split">
                                    <h2 class="card-title">Incident Report Trends</h2>
                                </div>
                                <div class="chart-placeholder">
                                    @if (_isLoading)
                                    {
                                        <div class="skeleton skeleton-chart"></div>
                                    }
                                    else if (incidentTrendData == null || !incidentTrendData.Any())
                                    {
                                        <div class="empty-state">
                                            <p class="empty-state-text">No incident trend data available.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <ApexChart TItem="IncidentTrendData"
                                                   @ref="incidentChart"
                                                   Height="@("250")"
                                                   Options="incidentLineChartOptions">
                                            <ApexPointSeries TItem="IncidentTrendData"
                                                             Items='incidentTrendData.Where(x => x.Category == "EMERGENCY").ToList()'
                                                             Name="Emergency"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                            <ApexPointSeries TItem="IncidentTrendData"
                                                             Items='incidentTrendData.Where(x => x.Category == "COMPLAINT").ToList()'
                                                             Name="Complaint"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                            <ApexPointSeries TItem="IncidentTrendData"
                                                             Items='incidentTrendData.Where(x => x.Category == "SUGGESTION").ToList()'
                                                             Name="Suggestion"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                            <ApexPointSeries TItem="IncidentTrendData"
                                                             Items='incidentTrendData.Where(x => x.Category == "OTHER").ToList()'
                                                             Name="Other"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                        </ApexChart>
                                    }
                                </div>
                            </div>
<div class="architectural-card line-chart-card">
                                <div class="card-header-split">
                                    <h2 class="card-title">Appointment Trends</h2>
                                </div>
                                <div class="chart-placeholder">
                                    @if (_isLoading)
                                    {
                                        <div class="skeleton skeleton-chart"></div>
                                    }
                                    else if (appTrendData == null || !appTrendData.Any())
                                    {
                                        <div class="empty-state">
                                            <p class="empty-state-text">No appointment trend data available.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <ApexChart TItem="AppointmentTrendData"
                                                   @ref="appointmentChart"
                                                   Height="@("250")"
                                                   Options="appLineChartOptions">
                                            <ApexPointSeries TItem="AppointmentTrendData"
                                                             Items='appTrendData.Where(x => x.Category == "DOCUMENT REQUEST").ToList()'
                                                             Name="Documents"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                            <ApexPointSeries TItem="AppointmentTrendData"
                                                             Items='appTrendData.Where(x => x.Category == "COMPLAINT AND MEDIATION").ToList()'
                                                             Name="Mediation"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                            <ApexPointSeries TItem="AppointmentTrendData"
                                                             Items='appTrendData.Where(x => x.Category == "PERMITS & CLEARANCES").ToList()'
                                                             Name="Permits"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                            <ApexPointSeries TItem="AppointmentTrendData"
                                                             Items='appTrendData.Where(x => x.Category == "COMMUNITY PROGRAMS").ToList()'
                                                             Name="Programs"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                            <ApexPointSeries TItem="AppointmentTrendData"
                                                             Items='appTrendData.Where(x => x.Category == "ASSISTANCE SERVICES").ToList()'
                                                             Name="Assistance"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="@(e => e.Month)"
                                                             YValue="@(e => e.Count)" />
                                        </ApexChart>
                                    }
                                </div>
                            </div>
                    </div>

                    <div class="dashboard-grid-2">
<div class="architectural-card pie-chart-card">
                                <div class="card-header-split">
                                    <h2 class="card-title">Community Post Statuses</h2>
                                </div>
                                <div class="pie-chart-container">
                                    @if (_isLoading)
                                    {
                                        <div class="skeleton skeleton-chart" style="border-radius: 50%; width: 200px; height: 200px; margin: 0 auto;"></div>
                                    }
                                    else if (postStatusData == null || !postStatusData.Any())
                                    {
                                        <div class="empty-state">
                                            <p class="empty-state-text">No post status data available.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <ApexChart TItem="CategoryData"
                                                   @ref="postStatusChart"
                                                   Height="@("300")"
                                                   Options="postStatusPieOptions">
                                            <ApexPointSeries TItem="CategoryData"
                                                             Items="postStatusData"
                                                             Name="Posts"
                                                             SeriesType="SeriesType.Donut"
                                                             XValue="@(e => e.Name)"
                                                             YValue="@(e => e.Value)" />
                                        </ApexChart>
                                    }
                                </div>
                            </div>
<div class="architectural-card pie-chart-card">
                                <div class="card-header-split">
                                    <h2 class="card-title">Incident Statuses</h2>
                                </div>
                                <div class="pie-chart-container">
                                    @if (_isLoading)
                                    {
                                        <div class="skeleton skeleton-chart" style="border-radius: 50%; width: 200px; height: 200px; margin: 0 auto;"></div>
                                    }
                                    else if (incidentStatuses == null || !incidentStatuses.Any())
                                    {
                                        <div class="empty-state">
                                            <p class="empty-state-text">No incident status data available.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <ApexChart TItem="CategoryData"
                                                   @ref="incidentCategoryChart"
                                                   Height="@("300")"
                                                   Options="pieChartOptions">
                                            <ApexPointSeries TItem="CategoryData"
                                                             Items="incidentStatuses"
                                                             Name="Incidents"
                                                             SeriesType="SeriesType.Donut"
                                                             XValue="@(e => e.Name)"
                                                             YValue="@(e => e.Value)" />
                                        </ApexChart>
                                    }
                                </div>
                            </div>
                    </div>

                    <div class="dashboard-grid-2">
                        <div class="dashboard-col">
<AdminDashboardTable 
    TableType="AdminDashboardTable.DashboardTableType.Verification"
    Title="User Verification"
    Headers="verificationHeaders"
    IsLoading="_isLoading"
    SkeletonRows="4"
    VerificationUsers="verificationUsers"
    OnViewAll="OnViewAllVerifications" />
                                <AdminDashboardTable 
                                    TableType="AdminDashboardTable.DashboardTableType.Incident"
                                    Title="Recent Incident Reports"
                                    Headers="incidentHeaders"
                                    IsLoading="_isLoading"
                                    SkeletonRows="4"
                                    IncidentReports="incidentReports"
                                    OnViewAll="OnViewAllIncidents" />
                        </div>
                        <div class="dashboard-col">
<AdminDashboardTable 
                                    TableType="AdminDashboardTable.DashboardTableType.CommunityPost"
                                    Title="Recent Community Posts"
                                    Headers="communityPostHeaders"
                                    IsLoading="_isLoading"
                                    SkeletonRows="3"
                                    CommunityPosts="communityPosts"
                                    OnViewAll="OnViewAllPosts" />
                                <AdminDashboardTable 
                                    TableType="AdminDashboardTable.DashboardTableType.Appointment"
                                    Title="Appointments"
                                    Headers="appointmentHeaders"
                                    IsLoading="_isLoading"
                                    SkeletonRows="4"
                                    Appointments="appointments"
                                    OnViewAll="OnViewAllAppointments" />
                        </div>
                    </div>
                }
                else
                {
                    <p class="placeholder-text">@FilterLabel View - Coming Soon</p>
                }
    </div>
}

@code {
    private ApexChart<RegistrationData> registrationChart = default!;
    private ApexChart<UserVerificationTrendData> verificationChart = default!;
    private ApexChart<IncidentTrendData> incidentChart = default!;
    private ApexChart<AppointmentTrendData> appointmentChart = default!;
    private ApexChart<CategoryData> postStatusChart = default!;
    private ApexChart<CategoryData> incidentCategoryChart = default!;

    private bool _isAuthorized = false;
    private bool _isLoading = true;
    private string adminFirstName = "Official Name";

    // Table headers
    private List<string> verificationHeaders = new() { "ID", "NAME", "DATE REGISTERED", "STATUS" };
    private List<string> incidentHeaders = new() { "ID", "COMPLAINANT", "TITLE", "CATEGORY", "DATE", "STATUS" };
    private List<string> communityPostHeaders = new() { "ID", "AUTHOR", "TOPIC", "DATE", "STATUS" };
    private List<string> appointmentHeaders = new() { "ID", "NAME", "CATEGORY", "SERVICE", "STATUS" };

    private List<RegistrationData> trendData = new();
    private List<VerificationUser> verificationUsers = new();
    private List<IncidentReport> incidentReports = new();
    private List<CommunityPost> communityPosts = new();
    private List<Appointment> appointments = new();
    private List<CategoryData> incidentStatuses = new();
    private List<AppointmentTrendData> appTrendData = new();
    private List<UserVerificationTrendData> verificationTrendData = new();
    private List<CategoryData> postStatusData = new();
    private List<IncidentTrendData> incidentTrendData = new();
    private List<IncidentReportDto> _allIncidentData = new();
    private int TotalIncidentsCount = 0;
    private int IncidentsTodayCount = 0;

    private string _fontFamily = "'Inter', system-ui, -apple-system, sans-serif";
    private string _primaryColor = "#3b82f6";
    private string _secondaryTextColor = "#64748b";
    private string _gridColor = "#f1f5f9";

    private ApexChartOptions<T> GetDefaultOptions<T>() where T : class
    {
        return new ApexChartOptions<T>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = false },
                Animations = new Animations { Enabled = true, Easing = Easing.Easeinout, Speed = 800 },
                FontFamily = _fontFamily
            },
            DataLabels = new DataLabels { Enabled = false },
            Xaxis = new XAxis
            {
                Labels = new XAxisLabels { Style = new AxisLabelStyle { FontSize = "11px", FontWeight = "600", Colors = _secondaryTextColor } },
                AxisBorder = new AxisBorder { Show = false },
                AxisTicks = new AxisTicks { Show = false }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Labels = new YAxisLabels { Style = new AxisLabelStyle { FontSize = "11px", FontWeight = "600", Colors = _secondaryTextColor } },
                }
            },
            Grid = new Grid
            {
                Show = true,
                BorderColor = _gridColor,
                StrokeDashArray = 4,
                Xaxis = new GridXAxis { Lines = new Lines { Show = false } },
                Yaxis = new GridYAxis { Lines = new Lines { Show = true } }
            },
            Tooltip = new Tooltip
            {
                Theme = Mode.Light,
                X = new TooltipX { Show = true }
            },
            Legend = new Legend
            {
                Position = LegendPosition.Top,
                HorizontalAlign = Align.Right,
                FontSize = "12px",
                FontWeight = "600",
                Labels = new LegendLabels { Colors = _secondaryTextColor }
            }
        };
    }

    private ApexChartOptions<RegistrationData> chartOptions = new();
    private ApexChartOptions<CategoryData> pieChartOptions = new();
    private ApexChartOptions<AppointmentTrendData> appLineChartOptions = new();
    private ApexChartOptions<UserVerificationTrendData> verificationChartOptions = new();
    private ApexChartOptions<CategoryData> postStatusPieOptions = new();
    private ApexChartOptions<IncidentTrendData> incidentLineChartOptions = new();

    public class RegistrationData
    {
        public string Month { get; set; } = "";
        public int Count { get; set; }
    }

    public class CategoryData
    {
        public string Name { get; set; } = "";
        public int Value { get; set; }
    }

    public class AppointmentTrendData
    {
        public string Month { get; set; } = "";
        public string Category { get; set; } = "";
        public int Count { get; set; }
    }

    public class UserVerificationTrendData
    {
