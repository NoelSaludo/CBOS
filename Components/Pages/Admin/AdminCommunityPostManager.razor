@page "/admin/feed"
@layout AdminDashboardLayout
@rendermode InteractiveServer
@using CBOS.Components.Services
@using CBOS.Components.Shared

@inject AdminCommunityManagerSupabase CommunityManager
@inject AdminSupabase AdminSupabase

<div class="management-container">
	<div class="welcome-section">
		<div class="welcome-orb orb-1"></div>
		<div class="welcome-orb orb-2"></div>
		<div class="welcome-text-group">
			<h1>Community Posts</h1>
			<p>Manage community feed submissions by status.</p>
		</div>
		<div class="welcome-actions">
			<button class="quick-action-btn" type="button" @onclick="LoadPostsAsync">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 2v6h-6"></path>
					<path d="M20 13a9 9 0 1 1-2.12-5.88L21 8"></path>
				</svg>
				Refresh Data
			</button>
		</div>
	</div>

	<div class="analytics-grid">
		<div class="stat-card">
			<div class="stat-card-top">
				<div class="stat-icon-wrapper blue">
					<span class="stat-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
							<polyline points="14 2 14 8 20 8"></polyline>
							<line x1="16" y1="13" x2="8" y2="13"></line>
							<line x1="16" y1="17" x2="8" y2="17"></line>
							<polyline points="10 9 9 9 8 9"></polyline>
						</svg>
					</span>
				</div>
				<div class="stat-badge today">Total</div>
			</div>
			<div class="stat-info">
				<div class="stat-number-wrapper">
					<p class="stat-number">@TotalPosts</p>
				</div>
				<h3>TOTAL POSTS</h3>
			</div>
		</div>
		<div class="stat-card">
			<div class="stat-card-top">
				<div class="stat-icon-wrapper orange">
					<span class="stat-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10"></circle>
							<polyline points="12 6 12 12 16 14"></polyline>
						</svg>
					</span>
				</div>
				<div class="stat-badge today">Pending</div>
			</div>
			<div class="stat-info">
				<div class="stat-number-wrapper">
					<p class="stat-number">@PendingPosts</p>
				</div>
				<h3>PENDING REVIEW</h3>
			</div>
		</div>
		<div class="stat-card">
			<div class="stat-card-top">
				<div class="stat-icon-wrapper green">
					<span class="stat-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
							<polyline points="22 4 12 14.01 9 11.01"></polyline>
						</svg>
					</span>
				</div>
				<div class="stat-badge today">Accepted</div>
			</div>
			<div class="stat-info">
				<div class="stat-number-wrapper">
					<p class="stat-number">@AcceptedPosts</p>
				</div>
				<h3>ACCEPTED</h3>
			</div>
		</div>
		<div class="stat-card">
			<div class="stat-card-top">
				<div class="stat-icon-wrapper red">
					<span class="stat-icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
							<line x1="12" y1="9" x2="12" y2="13"></line>
							<line x1="12" y1="17" x2="12.01" y2="17"></line>
						</svg>
					</span>
				</div>
				<div class="stat-badge urgent">Rejected</div>
			</div>
			<div class="stat-info">
				<div class="stat-number-wrapper">
					<p class="stat-number">@RejectedPosts</p>
				</div>
				<h3>REJECTED</h3>
			</div>
		</div>
	</div>

	<div class="section-divider">
		<p class="section-label">POSTS CONSOLE</p>
		<div class="section-line"></div>
	</div>

	<div class="filters-card architectural-card">
		<div class="search-box">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
			<input type="text" placeholder="Search by title or ID..." @bind="searchQuery" @bind:event="oninput" />
		</div>
		<div class="filter-groups">
			<select @bind="selectedStatus" class="filter-select">
				<option value="All">All Status</option>
				<option value="Pending">Pending</option>
				<option value="Accepted">Accepted</option>
				<option value="Rejected">Rejected</option>
			</select>
			<button class="icon-action reset-btn" @onclick="ResetFilters" title="Reset Filters">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"></path><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
			</button>
		</div>
	</div>

	@if (_isLoading)
	{
		<div class="architectural-card">
			<div class="placeholder-text">Loading community posts…</div>
		</div>
	}
	else if (!string.IsNullOrWhiteSpace(_loadError))
	{
		<div class="architectural-card">
			<div class="error-banner" role="alert">@_loadError</div>
			<div class="card-footer-center">
				<button class="action-btn secondary" type="button" @onclick="LoadPostsAsync">Retry</button>
			</div>
		</div>
	}
	else
	{
		@if (!string.IsNullOrWhiteSpace(_updateError))
		{
			<div class="error-banner" role="alert">@_updateError</div>
		}

		<div class="table-card architectural-card">
			<div class="table-container">
				<table class="data-table">
					<thead>
						<tr>
							<th>ID</th>
							<th>TITLE</th>
							<th>DATE</th>
							<th>STATUS</th>
							<th class="actions-header" style="text-align: center;">ACTIONS</th>
						</tr>
					</thead>
					<tbody>
						@if (!FilteredTickets.Any())
						{
							<tr>
								<td colspan="5">
									<div class="empty-state">
										<div class="empty-state-icon">
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
												<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
											</svg>
										</div>
										<p class="empty-state-text">No posts match your filters.</p>
									</div>
								</td>
							</tr>
						}
						else
						{
							@foreach (var ticket in FilteredTickets)
							{
								<tr class="clickable-row" @onclick="() => OpenDetailsModal(ticket)">
									<td class="id-cell">#POST-@ticket.PostId</td>
									<td class="bold-cell">@ticket.Title</td>
									<td class="light-cell">@ticket.CreatedAt.ToString("MMM dd, yyyy")</td>
									<td><span class="data-chip @GetStatusClass(ticket.Status)">@GetDisplayStatus(ticket.Status)</span></td>
									<td>
										<div class="row-actions" style="justify-content: center;">
											<button class="view-details-btn" @onclick="() => OpenDetailsModal(ticket)" @onclick:stopPropagation title="Manage Post">
												<span>Manage</span>
												<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
													<path d="M5 12h14"></path>
													<path d="m12 5 7 7-7 7"></path>
												</svg>
											</button>
										</div>
									</td>
								</tr>
							}
						}
					</tbody>
				</table>
			</div>
			<div class="table-footer">
				<div class="pagination-info">
					Showing <span>@FilteredTickets.Count</span> of <span>@AllTickets.Count</span> posts
				</div>
			</div>
		</div>
	}
</div>

@if (_showDetailsModal && _selectedTicket != null)
{
	<div class="modal-overlay">
		<div class="modal-content large">
			<div class="modal-header">
				<div class="modal-title-group">
					<div class="modal-icon-wrapper">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
						</svg>
					</div>
					<div class="modal-text">
						<h3>@_selectedTicket.Title</h3>
						<p>ID: <span class="id-text">#POST-@_selectedTicket.PostId</span></p>
					</div>
				</div>
				<div class="header-actions">
					<span class="data-chip @GetStatusClass(_selectedTicket.Status)">@GetDisplayStatus(_selectedTicket.Status)</span>
					<button class="close-btn" @onclick="CloseDetailsModal">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
					</button>
				</div>
			</div>
			<div class="modal-body details-grid">
				<div class="left-column">
					<div class="post-summary-card">
						<div class="summary-item">
							<span class="summary-label">POST ID</span>
							<span class="summary-value">#POST-@_selectedTicket.PostId</span>
						</div>
						<div class="summary-item">
							<span class="summary-label">DATE SUBMITTED</span>
							<span class="summary-value">@_selectedTicket.CreatedAt.ToString("MMM dd, yyyy • h:mm tt")</span>
						</div>
						<div class="summary-item full-width">
							<span class="summary-label">DESCRIPTION</span>
							<p class="description-text">@_selectedTicket.Description</p>
						</div>
					</div>
				</div>

				<div class="right-column">
					@if (!string.IsNullOrWhiteSpace(_selectedTicket.PrimaryImageUrl))
					{
						<div class="attachments-section">
							<span class="summary-label mb-2" style="display:block;">ATTACHED IMAGE</span>
							<div class="image-gallery">
								<div class="image-wrapper">
									<img src="@_selectedTicket.PrimaryImageUrl" class="attachment-thumbnail" alt="Post image" />
								</div>
							</div>
						</div>
					}

					<div class="status-selection-group mt-4">
						<span class="summary-label mb-2" style="display:block;">UPDATE STATUS</span>
						<div class="status-grid">
							<div class="status-card-option @(_newStatus == StatusPending ? "active" : "")" @onclick='() => _newStatus = StatusPending'>
								<div class="status-card-icon pending">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
								</div>
								<div class="status-card-info">
									<span class="status-name">Pending</span>
									<span class="status-desc">Needs review</span>
								</div>
								<div class="status-radio-mock"></div>
							</div>

							<div class="status-card-option @(_newStatus == StatusAccepted ? "active" : "")" @onclick='() => _newStatus = StatusAccepted'>
								<div class="status-card-icon resolved">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
								</div>
								<div class="status-card-info">
									<span class="status-name">Accepted</span>
									<span class="status-desc">Publish to feed</span>
								</div>
								<div class="status-radio-mock"></div>
							</div>

							<div class="status-card-option @(_newStatus == StatusRejected ? "active" : "")" @onclick='() => _newStatus = StatusRejected'>
								<div class="status-card-icon rejected">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
								</div>
								<div class="status-card-info">
									<span class="status-name">Rejected</span>
									<span class="status-desc">Remove from queue</span>
								</div>
								<div class="status-radio-mock"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button class="modal-btn secondary" @onclick="CloseDetailsModal">Cancel</button>
				<button class="modal-btn primary" disabled="@IsUpdating(_selectedTicket.TicketId)" @onclick="ConfirmStatusUpdate">
					<span>Confirm Update</span>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
				</button>
			</div>
		</div>
	</div>
}

@code {
	private readonly List<CommunityPostTicket> _tickets = new();
	private bool _isLoading = true;
	private string? _loadError;
	private string? _updateError;
	private readonly HashSet<long> _updatingTicketIds = new();
	private bool _showDetailsModal = false;
	private CommunityPostTicket? _selectedTicket;
	private string _newStatus = StatusPending;
	private string searchQuery = "";
	private string selectedStatus = "All";
	private long adminId;

	private const string StatusPending = "Pending";
	private const string StatusAccepted = "Accepted";
	private const string StatusRejected = "Rejected";

	// Analytics computed properties
	private int TotalPosts => _tickets.Count;
	private int PendingPosts => _tickets.Count(t => NormalizeStatus(t.Status) == StatusPending);
	private int AcceptedPosts => _tickets.Count(t => NormalizeStatus(t.Status) == StatusAccepted);
	private int RejectedPosts => _tickets.Count(t => NormalizeStatus(t.Status) == StatusRejected);

	private List<CommunityPostTicket> AllTickets => _tickets
		.OrderByDescending(t => t.CreatedAt)
		.ToList();

	private List<CommunityPostTicket> FilteredTickets => AllTickets
		.Where(t => (selectedStatus == "All" || NormalizeStatus(t.Status) == selectedStatus) &&
					(string.IsNullOrWhiteSpace(searchQuery) ||
					 t.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
					 t.PostId.ToString().Contains(searchQuery, StringComparison.OrdinalIgnoreCase)))
		.ToList();

	protected override async Task OnInitializedAsync()
	{
		adminId = AdminSupabase.GetCurrentAdminId();
		await LoadPostsAsync();
	}

	private async Task LoadPostsAsync()
	{
		_isLoading = true;
		_loadError = null;
		_updateError = null;

		try
		{
			_tickets.Clear();
			var approved = await CommunityManager.GetApprovedPostsAsync();
			var pending = await CommunityManager.GetPendingPostTicketsAsync();
			var rejected = await CommunityManager.GetRejectedPostTicketsAsync();
			_tickets.AddRange(approved);
			_tickets.AddRange(pending);
			_tickets.AddRange(rejected);
		}
		catch (Exception ex)
		{
			_loadError = $"Failed to load posts: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
		}
	}

	private string NormalizeStatus(string? status)
	{
		if (string.IsNullOrWhiteSpace(status)) return StatusPending;

		return status.Equals("Approved", StringComparison.OrdinalIgnoreCase)
			? StatusAccepted
			: status.Equals(StatusAccepted, StringComparison.OrdinalIgnoreCase)
				? StatusAccepted
				: status.Equals(StatusRejected, StringComparison.OrdinalIgnoreCase)
					? StatusRejected
					: StatusPending;
	}

	private string GetDisplayStatus(string? status) => NormalizeStatus(status);

	private string GetStatusClass(string? status) => NormalizeStatus(status) switch
	{
		StatusAccepted => "approved",
		StatusRejected => "rejected",
		_ => "pending"
	};

	private void OpenDetailsModal(CommunityPostTicket ticket)
	{
		_selectedTicket = ticket;
		_newStatus = NormalizeStatus(ticket.Status);
		_showDetailsModal = true;
	}

	private void CloseDetailsModal()
	{
		_showDetailsModal = false;
		_selectedTicket = null;
	}

	private async Task ConfirmStatusUpdate()
	{
		if (_selectedTicket == null || IsUpdating(_selectedTicket.TicketId))
			return;

		await UpdateStatusAsync(_selectedTicket, _newStatus);
		CloseDetailsModal();
	}

	private async Task UpdateStatusAsync(CommunityPostTicket ticket, string newStatus)
	{
		_updateError = null;

		if (!_updatingTicketIds.Add(ticket.TicketId))
			return;

		try
		{
			switch (newStatus)
			{
				case StatusAccepted:
					await CommunityManager.UpdatePostTicketStatusToApprovedAsync(ticket.TicketId, adminId);
					break;
				case StatusRejected:
					await CommunityManager.UpdatePostTicketStatusToRejectedAsync(ticket.TicketId, adminId);
					break;
				default:
					await CommunityManager.UpdatePostTicketStatusToPendingAsync(ticket.TicketId, adminId);
					break;
			}

			await LoadPostsAsync();
		}
		catch (Exception ex)
		{
			_updateError = $"Failed to update post: {ex.Message}";
		}
		finally
		{
			_updatingTicketIds.Remove(ticket.TicketId);
		}
	}

	private bool IsUpdating(long ticketId) => _updatingTicketIds.Contains(ticketId);

	private void ResetFilters()
	{
		searchQuery = "";
		selectedStatus = "All";
	}
}

