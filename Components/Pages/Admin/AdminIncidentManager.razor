@page "/admin/incidents"
@layout AdminDashboardLayout
@rendermode InteractiveServer
@using CBOS.Components.Layout
@using CBOS.Components.Shared
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

@if (!_isAuthorized)
{
    <div class="auth-loading">
        <div class="spinner"></div>
        <p>Verifying session…</p>
    </div>
}
else
{
    <div class="management-container">
        <div class="welcome-section">
            <div class="welcome-orb orb-1"></div>
            <div class="welcome-orb orb-2"></div>
            <div class="welcome-text-group">
                <h1>Incident Management</h1>
                <p>Monitor, review, and respond to community incident reports.</p>
            </div>
            <div class="welcome-actions">
                <button class="quick-action-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                    Export Data
                </button>
                <button class="quick-action-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    New Report
                </button>
            </div>
        </div>

        <div class="analytics-grid">
            <div class="stat-card">
                <div class="stat-card-top">
                    <div class="stat-icon-wrapper blue">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                <polyline points="10 9 9 9 8 9"></polyline>
                            </svg>
                        </span>
                    </div>
                    <div class="stat-badge today">Total</div>
                </div>
                <div class="stat-info">
                    <div class="stat-number-wrapper">
                        <p class="stat-number">@TotalIncidents</p>
                    </div>
                    <h3>TOTAL INCIDENTS</h3>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-card-top">
                    <div class="stat-icon-wrapper orange">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </span>
                    </div>
                    <div class="stat-badge today">Pending</div>
                </div>
                <div class="stat-info">
                    <div class="stat-number-wrapper">
                        <p class="stat-number">@PendingIncidents</p>
                    </div>
                    <h3>PENDING REVIEW</h3>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-card-top">
                    <div class="stat-icon-wrapper green">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                        </span>
                    </div>
                    <div class="stat-badge today">Resolved</div>
                </div>
                <div class="stat-info">
                    <div class="stat-number-wrapper">
                        <p class="stat-number">@ResolvedIncidents</p>
                    </div>
                    <h3>RESOLVED CASES</h3>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-card-top">
                    <div class="stat-icon-wrapper red">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                <line x1="12" y1="9" x2="12" y2="13"></line>
                                <line x1="12" y1="17" x2="12.01" y2="17"></line>
                            </svg>
                        </span>
                    </div>
                    <div class="stat-badge urgent">Urgent</div>
                </div>
                <div class="stat-info">
                    <div class="stat-number-wrapper">
                        <p class="stat-number">@EmergencyIncidents</p>
                    </div>
                    <h3>EMERGENCY REPORTS</h3>
                </div>
            </div>
        </div>

        <div class="section-divider">
            <p class="section-label">MANAGEMENT CONSOLE</p>
            <div class="section-line"></div>
        </div>

        <div class="filters-card architectural-card">
            <div class="search-box">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" placeholder="Search by ID, complainant, or title..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            <div class="filter-groups">
                <select @bind="selectedCategory" class="filter-select">
                    <option value="All">All Categories</option>
                    <option value="SUGGESTION">Suggestion</option>
                    <option value="COMPLAINT">Complaint</option>
                    <option value="EMERGENCY">Emergency</option>
                    <option value="OTHER">Other</option>
                </select>
                <select @bind="selectedStatus" class="filter-select">
                    <option value="All">All Status</option>
                    <option value="PENDING">Pending</option>
                    <option value="RESOLVED">Resolved</option>
                    <option value="REJECTED">Rejected</option>
                </select>
                <button class="icon-action reset-btn" @onclick="ResetFilters" title="Reset Filters">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"></path><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                </button>
            </div>
        </div>

        <div class="table-card architectural-card">
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>COMPLAINANT</th>
                            <th>TITLE</th>
                            <th>CATEGORY</th>
                            <th>DATE</th>
                            <th>STATUS</th>
                            <th class="actions-header" style="text-align: center;">DETAILS</th>
                            <th class="actions-header" style="text-align: center;">UPDATE STATUS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_isLoading)
                        {
                            @for (int i = 0; i < 6; i++)
                            {
                                <tr>
                                    <td><div class="skeleton skeleton-text" style="width: 70px;"></div></td>
                                    <td><div class="skeleton skeleton-text"></div></td>
                                    <td><div class="skeleton skeleton-text"></div></td>
                                    <td><div class="skeleton skeleton-text" style="width: 60px;"></div></td>
                                    <td><div class="skeleton skeleton-text" style="width: 80px;"></div></td>
                                    <td><div class="skeleton skeleton-text" style="width: 70px;"></div></td>
                                    <td><div class="skeleton skeleton-text" style="width: 80px;"></div></td>
                                    <td><div class="skeleton skeleton-text" style="width: 100px;"></div></td>
                                </tr>
                            }
                        }
                        else if (!FilteredReports.Any())
                        {
                            <tr>
                                <td colspan="8">
                                    <div class="empty-state">
                                        <div class="empty-state-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                                                <line x1="12" y1="9" x2="12" y2="13"></line>
                                                <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                            </svg>
                                        </div>
                                        <p class="empty-state-text">No incident reports found matching your criteria.</p>
                                        <button class="btn-link" @onclick="ResetFilters">Clear all filters</button>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var report in FilteredReports)
                            {
                                <tr class="clickable-row" @onclick="() => OpenDetailsModal(report)">
                                    <td class="id-cell">@report.Id</td>
                                    <td class="bold-cell">
                                        <div class="user-avatar-group">
                                            <div class="avatar-circle">@report.Complainant[0]</div>
                                            <div class="name-details">
                                                <span>@report.Complainant</span>
                                                <span class="sub-text">Complainant</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="light-cell">@report.Title</td>
                                    <td><span class="data-chip @report.CategoryClass">@report.Category</span></td>
                                    <td class="light-cell">@report.Date</td>
                                    <td><span class="data-chip @report.StatusClass">@report.Status</span></td>
                                    <td>
                                        <div class="row-actions" style="justify-content: center;">
                                            <button class="view-details-btn" @onclick="() => OpenDetailsModal(report)" @onclick:stopPropagation>
                                                View Details
                                            </button>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="row-actions" style="justify-content: center;">
                                            <button class="update-status-btn" @onclick="() => OpenUpdateStatusModal(report)" @onclick:stopPropagation>
                                                Update Status
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer">
                <div class="pagination-info">
                    Showing <span>@FilteredReports.Count</span> of <span>@incidentReports.Count</span> reports
                </div>
                <div class="pagination-controls">
                    <button class="page-btn" disabled>&lt;</button>
                    <button class="page-btn active">1</button>
                    <button class="page-btn">2</button>
                    <button class="page-btn">3</button>
                    <button class="page-btn">&gt;</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDetailsModal && _selectedReport != null)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <div class="modal-title-group">
                    <div class="modal-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </div>
                    <div class="modal-text">
                        <h3>Incident Details</h3>
                        <p>Comprehensive overview of the report</p>
                    </div>
                </div>
                <button class="close-btn" @onclick="CloseDetailsModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="incident-summary-card">
                    <div class="summary-item">
                        <span class="summary-label">REPORT ID</span>
                        <span class="summary-value id-text">@_selectedReport.Id</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">DATE SUBMITTED</span>
                        <span class="summary-value">@_selectedReport.Date</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">COMPLAINANT</span>
                        <span class="summary-value">@_selectedReport.Complainant</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">CATEGORY</span>
                        <span class="data-chip @_selectedReport.CategoryClass">@_selectedReport.Category</span>
                    </div>
                    <div class="summary-item full-width">
                        <span class="summary-label">TITLE</span>
                        <span class="summary-value">@_selectedReport.Title</span>
                    </div>
                    <div class="summary-item full-width">
                        <span class="summary-label">STATUS</span>
                        <span class="data-chip @_selectedReport.StatusClass">@_selectedReport.Status</span>
                    </div>
                </div>

                <div class="details-section">
                    <p style="font-size: 0.85rem; color: var(--secondary); line-height: 1.6;">
                        This incident report was filed regarding <strong>@_selectedReport.Title</strong>. 
                        The current status is marked as <strong>@_selectedReport.Status</strong>. 
                        Further investigation and actions may be required based on the category of <strong>@_selectedReport.Category</strong>.
                    </p>
                </div>
            </div>
            <div class="modal-footer">
                <button class="modal-btn secondary" @onclick="CloseDetailsModal">Close</button>
                <button class="modal-btn primary" @onclick="() => OpenUpdateStatusModal(_selectedReport)">
                    <span>Update Status</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                </button>
            </div>
        </div>
    </div>
}

@if (_showUpdateModal && _selectedReport != null)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <div class="modal-title-group">
                    <div class="modal-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    </div>
                    <div class="modal-text">
                        <h3>Update Incident Status</h3>
                        <p>Change the current progress of this report</p>
                    </div>
                </div>
                <button class="close-btn" @onclick="CloseModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="incident-summary-card">
                    <div class="summary-item">
                        <span class="summary-label">REPORT ID</span>
                        <span class="summary-value id-text">@_selectedReport.Id</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">COMPLAINANT</span>
                        <span class="summary-value">@_selectedReport.Complainant</span>
                    </div>
                    <div class="summary-item full-width">
                        <span class="summary-label">TITLE</span>
                        <span class="summary-value">@_selectedReport.Title</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">CURRENT STATUS</span>
                        <span class="data-chip @_selectedReport.StatusClass">@_selectedReport.Status</span>
                    </div>
                </div>
                
                <div class="status-selection-group">
                    <label class="group-label">Select New Status</label>
                    <div class="status-grid">
                        <div class="status-card-option @(_newStatus == "PENDING" ? "active" : "")" @onclick='() => _newStatus = "PENDING"'>
                            <div class="status-card-icon pending">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            </div>
                            <div class="status-card-info">
                                <span class="status-name">Pending</span>
                                <span class="status-desc">Under investigation</span>
                            </div>
                            <div class="status-radio-mock"></div>
                        </div>

                        <div class="status-card-option @(_newStatus == "RESOLVED" ? "active" : "")" @onclick='() => _newStatus = "RESOLVED"'>
                            <div class="status-card-icon resolved">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                            </div>
                            <div class="status-card-info">
                                <span class="status-name">Resolved</span>
                                <span class="status-desc">Issue has been fixed</span>
                            </div>
                            <div class="status-radio-mock"></div>
                        </div>

                        <div class="status-card-option @(_newStatus == "REJECTED" ? "active" : "")" @onclick='() => _newStatus = "REJECTED"'>
                            <div class="status-card-icon rejected">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
                            </div>
                            <div class="status-card-info">
                                <span class="status-name">Rejected</span>
                                <span class="status-desc">Invalid or duplicate</span>
                            </div>
                            <div class="status-radio-mock"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="modal-btn secondary" @onclick="CloseModal">Cancel</button>
                <button class="modal-btn primary" @onclick="ConfirmStatusUpdate">
                    <span>Update Status</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _isAuthorized = false;
    private string searchQuery = "";
    private string selectedCategory = "All";
    private string selectedStatus = "All";
    private List<IncidentReport> incidentReports = new();

    private int TotalIncidents => incidentReports.Count;
    private int PendingIncidents => incidentReports.Count(r => r.Status == "PENDING");
    private int ResolvedIncidents => incidentReports.Count(r => r.Status == "RESOLVED");
    private int EmergencyIncidents => incidentReports.Count(r => r.Category == "EMERGENCY");

    // Modal State
    private bool _showUpdateModal = false;
    private bool _showDetailsModal = false;
    private IncidentReport? _selectedReport;
    private string _newStatus = "";

    private List<IncidentReport> FilteredReports => incidentReports
        .Where(r => (selectedCategory == "All" || r.Category == selectedCategory) &&
                    (selectedStatus == "All" || r.Status == selectedStatus) &&
                    (string.IsNullOrWhiteSpace(searchQuery) || 
                     r.Complainant.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) || 
                     r.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) || 
                     r.Id.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)))
        .ToList();

    [Inject] private ProtectedSessionStorage ProtectedSessionStorage { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private AdminSupabase AdminSupabase { get; set; } = default!;
    [Inject] private ILogger<AdminIncidentManager> Logger { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var result = await ProtectedSessionStorage.GetAsync<string>("adminSessionKey");

            if (!result.Success || string.IsNullOrWhiteSpace(result.Value))
            {
                Logger.LogWarning("No adminSessionKey found in ProtectedSessionStorage.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            var isValid = await AdminSupabase.CheckSessionKey(result.Value);

            if (!isValid)
            {
                Logger.LogWarning("adminSessionKey exists but is invalid or expired.");
                Navigation.NavigateTo("/admin/access-denied");
                return;
            }

            _isAuthorized = true;
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error validating admin session.");
            Navigation.NavigateTo("/admin/access-denied");
        }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        // Simulate loading
        await Task.Delay(1000);

        incidentReports = new List<IncidentReport>
        {
            new IncidentReport { Id = "#INC-4021", Complainant = "Maria Santos", Title = "Stray Animal Complaint", Category = "COMPLAINT", Date = "Oct 24, 2023", Status = "PENDING" },
            new IncidentReport { Id = "#INC-4020", Complainant = "Juan Dela Cruz", Title = "Noise Disturbance", Category = "COMPLAINT", Date = "Oct 23, 2023", Status = "RESOLVED" },
            new IncidentReport { Id = "#INC-4019", Complainant = "Elena Rodriguez", Title = "Clogged Drainage", Category = "OTHER", Date = "Oct 22, 2023", Status = "PENDING" },
            new IncidentReport { Id = "#INC-4018", Complainant = "Mark Jayson Sy", Title = "New Park Benches", Category = "SUGGESTION", Date = "Oct 22, 2023", Status = "PENDING" },
            new IncidentReport { Id = "#INC-4017", Complainant = "Liza Soberano", Title = "Illegal Parking", Category = "COMPLAINT", Date = "Oct 21, 2023", Status = "REJECTED" },
            new IncidentReport { Id = "#INC-4016", Complainant = "Ricardo Dalisay", Title = "Gas Leak", Category = "EMERGENCY", Date = "Oct 20, 2023", Status = "RESOLVED" },
            new IncidentReport { Id = "#INC-4015", Complainant = "Berna Mea", Title = "Broken Water Pipe", Category = "OTHER", Date = "Oct 19, 2023", Status = "RESOLVED" },
            new IncidentReport { Id = "#INC-4014", Complainant = "Jose Mari Chan", Title = "Holiday Decor Suggestion", Category = "SUGGESTION", Date = "Sep 01, 2023", Status = "PENDING" }
        };

        _isLoading = false;
    }

    private void OpenUpdateStatusModal(IncidentReport report)
    {
        _selectedReport = report;
        _newStatus = report.Status;
        _showUpdateModal = true;
        _showDetailsModal = false;
    }

    private void OpenDetailsModal(IncidentReport report)
    {
        _selectedReport = report;
        _showDetailsModal = true;
        _showUpdateModal = false;
    }

    private void CloseModal()
    {
        _showUpdateModal = false;
        _selectedReport = null;
    }

    private void CloseDetailsModal()
    {
        _showDetailsModal = false;
        _selectedReport = null;
    }

    private async Task ConfirmStatusUpdate()
    {
        if (_selectedReport != null)
        {
            // In a real app, you would call your service here
            // await AdminSupabase.UpdateIncidentStatus(_selectedReport.Id, _newStatus);
            
            _selectedReport.Status = _newStatus;
            
            // Mocking a short delay for UX
            await Task.Delay(300);
            
            CloseModal();
            StateHasChanged();
        }
    }

    private void ResetFilters()
    {
        searchQuery = "";
        selectedCategory = "All";
        selectedStatus = "All";
    }

    public class IncidentReport
    {
        public string Id { get; set; } = string.Empty;
        public string Complainant { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public string Date { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;

        public string CategoryClass => Category.ToUpper() switch
        {
            "SUGGESTION" => "review",
            "COMPLAINT" => "yellow",
            "EMERGENCY" => "red",
            "OTHER" => "gray",
            _ => "gray"
        };

        public string StatusClass => Status.ToUpper() switch
        {
            "PENDING" => "pending",
            "RESOLVED" => "resolved",
            "REJECTED" => "rejected",
            _ => "gray"
        };
    }
}
