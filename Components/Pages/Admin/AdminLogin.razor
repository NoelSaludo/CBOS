@page "/Admin/Login"
@layout AdminLoginLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using CBOS.Components.Shared

@inject NavigationManager Navigation
@inject ILogger<AdminLogin> Logger
@inject AdminSupabase AdminSupabase
@inject ProtectedSessionStorage ProtectedSessionStorage

@rendermode InteractiveServer

<div class="login-card align-content-center">
    <div class="login-card-header">
        <h3>Administrator Login</h3>
        <h6>Authorized Personnel Only. System activity is being monitored.</h6>
    </div>
    <EditForm Model="@Model" OnValidSubmit="OnValidSubmit" FormName="admin-login-form">
        <DataAnnotationsValidator />
        @if (!string.IsNullOrEmpty(LoginWarning))
        {
            <div class="alert alert-warning" role="alert">
                @LoginWarning
            </div>
        }
        <div class="mb-3">
            <InputText class="form-control capsule" id="adminId" placeholder="Administrator ID"
                        @bind-Value="Model.id" />
            <ValidationMessage For="@(() => Model.id)" class="text-danger" />
        </div>
        <div class="mb-3">
            <div class="password-field">
                <div class="password-input-wrap">
                    <InputText class="form-control password-input capsule" type="@(showPassword ? "text" : "password")" id="password"
                                placeholder="Password" @bind-Value="Model.password" />
                    <InputCheckbox class="password-toggle-input" id="showPassword" @bind-Value="showPassword" style="visibility: hidden;"/>
                    <label class="password-toggle" for="showPassword" aria-label="Toggle password visibility">
                        <svg class="eye-closed" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20C7 20 2.73 16.11 1 12c.74-1.66 1.92-3.36 3.46-4.73"></path>
                            <path d="M10.58 10.58a2 2 0 0 0 2.84 2.84"></path>
                            <path d="M9.88 4.24A10.94 10.94 0 0 1 12 4c5 0 9.27 3.89 11 8-1.11 2.5-3.13 4.77-5.75 6.06"></path>
                            <line x1="1" y1="1" x2="23" y2="23"></line>
                        </svg>
                        <svg class="eye-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </label>
                </div>
                <ValidationMessage For="@(() => Model.password)" class="text-danger" />
            </div>
        </div>
        <button type="submit" class="btn btn-primary submit-btn">Submit</button>
    </EditForm>
</div>

@code {
    private AdminLoginModel? Model;
    private string? LoginWarning;
    private bool showPassword;
 
    protected override void OnInitialized()
    {
        Model = new();
    }

    public async Task OnValidSubmit()
    {
        Logger.LogInformation("Attempting admin login with ID: {AdminId}", Model?.id);

        var result = await AdminSupabase.LoginAndSetCurrentAdmin(Model?.id ?? string.Empty, Model?.password ?? string.Empty);
        switch (result.Code)
        {
            case AdminSupabaseCode.Success:
                // store session key in local storage or cookie
                var sessionKey = result.sessionToken;

                await ProtectedSessionStorage.SetAsync("adminSessionKey", sessionKey);

                Navigation.NavigateTo("/admin/app");
                break;

            case AdminSupabaseCode.InvalidCredentials:
                LoginWarning = "Invalid ID or password. Please try again.";
                break;

            case AdminSupabaseCode.AdminNotFound:
                LoginWarning = "No admin found with the provided ID.";
                break;

            default:
                LoginWarning = "An unexpected error occurred. Please try again later.";
                break;
        }
    }


    public class AdminLoginModel
    {
        [Required]
        public string? id { get; set; }
        [Required]
        public string? password { get; set; }
    }
}