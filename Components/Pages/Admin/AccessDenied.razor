@page "/admin/access-denied"
@layout BlankLayout

@rendermode InteractiveServer

<div class="denied-wrapper">
    <div class="background-logo">
        <img src="/images/cbos-logo-outline.png" alt="" />
    </div>
    <div class="denied-card">
        <div class="denied-icon-container">
            <svg class="denied-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path class="lock-shackle" d="M7 11V7a5 5 0 0 1 10 0v4" />
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" fill="currentColor" stroke="none" />
                <path d="M12 14.5v3" stroke="rgba(255,255,255,0.5)" />
            </svg>
        </div>
        <h1 class="denied-title">Access Denied</h1>
        <p class="denied-message">
            You do not have permission to access the administrative dashboard.<br />
            Please log in with an authorized account to continue.
        </p>
        <div class="actions">
            <a href="/Admin/Login" class="back-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                Sign in to Admin
            </a>
            <a href="/" class="secondary-btn">Return to Public Home</a>
        </div>
    </div>
</div>