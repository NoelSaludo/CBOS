@page "/admin/appointments"
@using CBOS.Components.Model
@using CBOS.Components.Services
@using CBOS.Components.Shared
@layout AdminDashboardLayout

@inject AppointmentTicketSupabase TicketService
@inject AdminSupabase AdminService

@rendermode InteractiveServer

<div class="management-container">
    <div class="welcome-section">
        <div class="welcome-orb orb-1"></div>
        <div class="welcome-orb orb-2"></div>
        <div class="welcome-text-group">
            <h1>Appointments</h1>
            <p>Review and update appointment requests by status.</p>
        </div>
        <div class="welcome-actions">
            <button class="quick-action-btn" type="button" @onclick="LoadTicketsAsync">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 2v6h-6"></path>
                    <path d="M20 13a9 9 0 1 1-2.12-5.88L21 8"></path>
                </svg>
                Refresh Data
            </button>
        </div>
    </div>

    <div class="section-divider">
        <p class="section-label">APPOINTMENT CONSOLE</p>
        <div class="section-line"></div>
    </div>

    @if (_isLoading)
    {
        <div class="architectural-card">
            <div class="placeholder-text">Loading appointments…</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <div class="architectural-card">
            <div class="error-banner" role="alert">@_loadError</div>
            <div class="card-footer-center">
                <button class="action-btn secondary" type="button" @onclick="LoadTicketsAsync">Retry</button>
            </div>
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_updateError))
        {
            <div class="error-banner" role="alert">@_updateError</div>
        }

        <div class="table-card architectural-card">
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>RESIDENT</th>
                            <th>TYPE</th>
                            <th>SCHEDULE</th>
                            <th>STATUS</th>
                            <th class="actions-header" style="text-align: center;">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!_items.Any())
                        {
                            <tr>
                                <td colspan="6">
                                    <div class="empty-state">
                                        <div class="empty-state-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                                <polyline points="14 2 14 8 20 8"></polyline>
                                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                            </svg>
                                        </div>
                                        <p class="empty-state-text">No appointments found.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var ticket in SortedTickets)
                            {
                                <tr class="clickable-row" @onclick="() => OpenDetailsModal(ticket)">
                                    <td class="id-cell">#TKT-@ticket.TicketId</td>
                                    <td class="bold-cell">@ticket.FullName</td>
                                    <td class="light-cell">@ticket.AppointmentType</td>
                                    <td class="light-cell">@ticket.ScheduledDate.ToLocalTime().ToString("MMM dd, yyyy • h:mm tt")</td>
                                    <td><span class="data-chip @GetStatusClass(ticket.Status)">@NormalizeStatus(ticket.Status)</span></td>
                                    <td>
                                        <div class="row-actions" style="justify-content: center;">
                                            <button class="view-details-btn" @onclick="() => OpenDetailsModal(ticket)" @onclick:stopPropagation title="Manage Appointment">
                                                <span>Manage</span>
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M5 12h14"></path>
                                                    <path d="m12 5 7 7-7 7"></path>
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer">
                <div class="pagination-info">
                    Showing <span>@SortedTickets.Count</span> appointments
                </div>
            </div>
        </div>
    }
</div>

@if (_showDetailsModal && _selectedTicket != null)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <div class="modal-title-group">
                    <div class="modal-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                    </div>
                    <div class="modal-text">
                        <h3>@_selectedTicket.FullName</h3>
                        <p>ID: <span class="id-text">#TKT-@_selectedTicket.TicketId</span></p>
                    </div>
                </div>
                <div class="header-actions">
                    <span class="data-chip @GetStatusClass(_selectedTicket.Status)">@NormalizeStatus(_selectedTicket.Status)</span>
                    <button class="close-btn" @onclick="CloseDetailsModal">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <div class="appointment-summary-card">
                    <div class="summary-item">
                        <span class="summary-label">APPOINTMENT TYPE</span>
                        <span class="summary-value">@_selectedTicket.AppointmentType</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">SCHEDULED FOR</span>
                        <span class="summary-value">@_selectedTicket.ScheduledDate.ToLocalTime().ToString("MMM dd, yyyy • h:mm tt")</span>
                    </div>
                    <div class="summary-item full-width">
                        <span class="summary-label">DESCRIPTION</span>
                        <p class="description-text">@_selectedTicket.Description</p>
                    </div>
                </div>

                <div class="status-selection-group">
                    <span class="group-label">UPDATE STATUS</span>
                    <div class="status-grid">
                        <div class="status-card-option @(_newStatus == StatusPending ? "active" : "")" @onclick='() => _newStatus = StatusPending'>
                            <div class="status-card-icon pending">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            </div>
                            <div class="status-card-info">
                                <span class="status-name">Pending</span>
                                <span class="status-desc">Awaiting review</span>
                            </div>
                            <div class="status-radio-mock"></div>
                        </div>

                        <div class="status-card-option @(_newStatus == StatusAccepted ? "active" : "")" @onclick='() => _newStatus = StatusAccepted'>
                            <div class="status-card-icon resolved">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                            </div>
                            <div class="status-card-info">
                                <span class="status-name">Accepted</span>
                                <span class="status-desc">Approved schedule</span>
                            </div>
                            <div class="status-radio-mock"></div>
                        </div>

                        <div class="status-card-option @(_newStatus == StatusRejected ? "active" : "")" @onclick='() => _newStatus = StatusRejected'>
                            <div class="status-card-icon rejected">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
                            </div>
                            <div class="status-card-info">
                                <span class="status-name">Rejected</span>
                                <span class="status-desc">Declined request</span>
                            </div>
                            <div class="status-radio-mock"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="modal-btn secondary" @onclick="CloseDetailsModal">Cancel</button>
                <button class="modal-btn primary" disabled="@IsUpdating(_selectedTicket.TicketId)" @onclick="ConfirmStatusUpdate">
                    <span>Confirm Update</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<AppointmentTicketModel> _items = new();
    private bool _isLoading = true;
    private string? _loadError;
    private string? _updateError;
    private readonly HashSet<long> _updatingTicketIds = new();
    private bool _showDetailsModal = false;
    private AppointmentTicketModel? _selectedTicket;
    private string _newStatus = StatusPending;

    private const string StatusPending = "Pending";
    private const string StatusAccepted = "Accepted";
    private const string StatusRejected = "Rejected";

    protected override async Task OnInitializedAsync()
    {
        await LoadTicketsAsync();
    }

    private List<AppointmentTicketModel> SortedTickets =>
        _items.OrderByDescending(i => i.ScheduledDate).ToList();

    private static string NormalizeStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return StatusPending;

        var normalized = status.Trim();
        return normalized.Equals(StatusAccepted, StringComparison.OrdinalIgnoreCase) ? StatusAccepted
            : normalized.Equals(StatusRejected, StringComparison.OrdinalIgnoreCase) ? StatusRejected
            : normalized.Equals("Rejected", StringComparison.OrdinalIgnoreCase) ? StatusRejected
            : normalized.Equals("Approved", StringComparison.OrdinalIgnoreCase) ? StatusAccepted
            : StatusPending;
    }

    private async Task LoadTicketsAsync()
    {
        _isLoading = true;
        _loadError = null;
        _updateError = null;

        try
        {
            _items = await TicketService.GetAppointmentBoardAsync();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load appointments: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool IsUpdating(long ticketId) => _updatingTicketIds.Contains(ticketId);

    private string GetStatusClass(string? status) => NormalizeStatus(status) switch
    {
        StatusPending => "pending",
        StatusAccepted => "approved",
        StatusRejected => "rejected",
        _ => "pending"
    };

    private void OpenDetailsModal(AppointmentTicketModel ticket)
    {
        _selectedTicket = ticket;
        _newStatus = NormalizeStatus(ticket.Status);
        _showDetailsModal = true;
    }

    private void CloseDetailsModal()
    {
        _showDetailsModal = false;
        _selectedTicket = null;
    }

    private async Task ConfirmStatusUpdate()
    {
        if (_selectedTicket == null || IsUpdating(_selectedTicket.TicketId))
            return;

        await UpdateStatusAsync(_selectedTicket, _newStatus);
        CloseDetailsModal();
    }

    private async Task UpdateStatusAsync(AppointmentTicketModel ticket, string newStatus)
    {
        _updateError = null;

        if (!_updatingTicketIds.Add(ticket.TicketId))
            return;

        try
        {
            await TicketService.UpdateAppointmentTicketStatusAsync(ticket.TicketId, newStatus, AdminService.GetCurrentAdminId());
            ticket.Status = newStatus;
        }
        catch (Exception ex)
        {
            _updateError = $"Failed to update appointment: {ex.Message}";
        }
        finally
        {
            _updatingTicketIds.Remove(ticket.TicketId);
        }
    }
}