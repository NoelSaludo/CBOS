@page "/app/appointments"
@layout MainLayout

<div class="appointment-container">
    <div class="appointment-card">
        <div class="appointment-header">
            <button class="back-btn">←</button>
            <h1>Schedule an Appointment</h1>
        </div>
        <div class="appointment-content">
            <!-- Left: Reason for appointment -->
            <div class="appointment-reasons">
                <div class="reason-group">
                    <button class="reason-main">Document Requests</button>
                </div>
                <div class="reason-group active">
                    <button class="reason-main selected">Complaint & Mediation</button>
                    <div class="reason-sub">
                        <label><input type="radio" name="complaintType" checked> Mediation / Complaint Hearing</label>
                        <label><input type="radio" name="complaintType"> Blotter Report Filing</label>
                    </div>
                </div>
                <div class="reason-group">
                    <button class="reason-main">Permits & Clearances</button>
                </div>
                <div class="reason-group">
                    <button class="reason-main">Community Programs</button>
                </div>
                <div class="reason-group">
                    <button class="reason-main">Assistance Services</button>
                    <div class="reason-note">Additional requirement per appointment type reminder here if any*</div>
                </div>
            </div>
            <!-- Center: Description & Calendar -->
            <div class="appointment-details">
                <div class="desc-group">
                    <label>Add short description (optional)</label>
                    <textarea placeholder="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse euismod erat sed odio convallis."></textarea>
                </div>
                <div class="calendar-group">
                    <label>Pick a schdule available</label>
                    <div class="calendar-mock">
                        <div class="calendar-header">
                            <button class="cal-nav" @onclick="PreviousMonth">←</button>
                            <span>@CurrentDate.ToString("MMMM yyyy")</span>
                            <button class="cal-nav" @onclick="NextMonth">→</button>
                        </div>
                        <table class="calendar-table">
                            <thead>
                                <tr><th>Sun</th><th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var week in GetCalendarWeeks())
                                {
                                    <tr>
                                        @foreach (var day in week)
                                        {
                                            @if (day == 0)
                                            {
                                                <td class="inactive"></td>
                                            }
                                            else if (day == SelectedDay && CurrentDate.Year == SelectedDate.Year && CurrentDate.Month == SelectedDate.Month)
                                            {
                                                <td class="selected" @onclick="() => SelectDate(day)">@day</td>
                                            }
                                            else
                                            {
                                                <td @onclick="() => SelectDate(day)">@day</td>
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <!-- Right: Notice & Submit -->
            <div class="appointment-side">
                <div class="notice-title">Notice</div>
                <div class="notice-text">
                    After submission of requested appointment schedule, wait for pending approval from barangay admins. Expect re-schedules or rejection especially on very busy days
                </div>
                <button class="submit-btn">Submit</button>
            </div>
        </div>
    </div>
</div>

<style>
.appointment-container {
    min-height: 100vh;
    background: linear-gradient(135deg, #00B4D8 0%, #2196f3 100%);
    padding: 0;
    margin: 0;
}
.appointment-card {
    background: #fff;
    border-radius: 32px;
    max-width: 950px;
    margin: 40px auto;
    box-shadow: 0 4px 32px rgba(0,0,0,0.10);
    padding: 0 0 32px 0;
}
.appointment-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 32px 32px 0 32px;
}
.appointment-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1b8ef2;
    margin: 0;
}
.back-btn {
    background: none;
    border: none;
    font-size: 2rem;
    color: #1b8ef2;
    cursor: pointer;
    margin-right: 8px;
}
.appointment-content {
    display: flex;
    gap: 32px;
    padding: 24px 32px 0 32px;
}
.appointment-reasons {
    flex: 1.2;
    display: flex;
    flex-direction: column;
    gap: 12px;
}
.reason-group {
    background: #f5f7fa;
    border-radius: 12px;
    margin-bottom: 4px;
    padding: 0;
}
.reason-main {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    font-size: 1.1rem;
    font-weight: 600;
    color: #888;
    padding: 12px 16px;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
}
.reason-main.selected, .reason-group.active .reason-main {
    background: #1b8ef2;
    color: #fff;
}
.reason-sub {
    padding: 8px 24px 8px 32px;
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.reason-note {
    font-size: 0.9rem;
    color: #aaa;
    padding: 8px 16px 8px 32px;
}
.appointment-details {
    flex: 2.2;
    display: flex;
    flex-direction: column;
    gap: 24px;
}
.desc-group label {
    font-size: 1.1rem;
    font-weight: 500;
    color: #888;
}
.desc-group textarea {
    width: 100%;
    min-height: 60px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    padding: 12px;
    margin-top: 8px;
    font-size: 1rem;
    background: #f7f7f7;
    color: #444;
    resize: none;
}
.calendar-group label {
    font-size: 1.1rem;
    font-weight: 500;
    color: #888;
    margin-bottom: 8px;
    display: block;
}
.calendar-mock {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    padding: 16px;
    width: 320px;
}
.calendar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-weight: 600;
    color: #1b8ef2;
    margin-bottom: 8px;
}
.cal-nav {
    background: none;
    border: none;
    font-size: 1.2rem;
    color: #1b8ef2;
    cursor: pointer;
}
.calendar-table {
    width: 100%;
    border-collapse: collapse;
    text-align: center;
    font-size: 1rem;
    color: #444;
}
.calendar-table th {
    color: #aaa;
    font-weight: 500;
    padding-bottom: 4px;
}
.calendar-table td {
    padding: 4px 0;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
}
.calendar-table td.selected {
    background: #1b8ef2;
    color: #fff;
    font-weight: 700;
}
.calendar-table td.inactive {
    color: #ccc;
    cursor: default;
}
.appointment-side {
    flex: 1.2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    padding-left: 16px;
}
.notice-title {
    color: #1b8ef2;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 4px;
}
.notice-text {
    color: #aaa;
    font-size: 0.98rem;
    line-height: 1.4;
    margin-bottom: 16px;
}
.submit-btn {
    background: #1b8ef2;
    color: #fff;
    border: none;
    border-radius: 24px;
    padding: 12px 36px;
    font-size: 1.2rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 16px;
}
.submit-btn:hover {
    background: #1976d2;
}
@@media (max-width: 1100px) {
    .appointment-content {
        flex-direction: column;
        gap: 24px;
    }
    .appointment-side {
        align-items: stretch;
        padding-left: 0;
    }
    .calendar-mock {
        width: 100%;
    }
}
@@media (max-width: 700px) {
    .appointment-card {
        border-radius: 0;
        margin: 0;
        box-shadow: none;
        padding: 0;
    }
    .appointment-header, .appointment-content {
        padding: 16px;
    }
}
</style>

@code {
    private DateTime CurrentDate = DateTime.Now;
    private DateTime SelectedDate = DateTime.Now;
    private int SelectedDay = DateTime.Now.Day;

    private void NextMonth()
    {
        CurrentDate = CurrentDate.AddMonths(1);
    }

    private void PreviousMonth()
    {
        CurrentDate = CurrentDate.AddMonths(-1);
    }

    private void SelectDate(int day)
    {
        SelectedDate = new DateTime(CurrentDate.Year, CurrentDate.Month, day);
        SelectedDay = day;
    }

    private List<List<int>> GetCalendarWeeks()
    {
        var weeks = new List<List<int>>();
        var firstDayOfMonth = new DateTime(CurrentDate.Year, CurrentDate.Month, 1);
        var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);
        
        // Get the day of week for the first day (0 = Sunday, 6 = Saturday)
        int firstDayOfWeek = (int)firstDayOfMonth.DayOfWeek;
        
        var currentWeek = new List<int>();
        
        // Add empty cells for days before the first day of the month
        for (int i = 0; i < firstDayOfWeek; i++)
        {
            currentWeek.Add(0);
        }
        
        // Add days of the month
        for (int day = 1; day <= lastDayOfMonth.Day; day++)
        {
            currentWeek.Add(day);
            if (currentWeek.Count == 7)
            {
                weeks.Add(currentWeek);
                currentWeek = new List<int>();
            }
        }
        
        // Add remaining empty cells
        while (currentWeek.Count > 0 && currentWeek.Count < 7)
        {
            currentWeek.Add(0);
        }
        
        if (currentWeek.Count > 0)
        {
            weeks.Add(currentWeek);
        }
        
        return weeks;
    }
}

