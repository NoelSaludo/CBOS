@page "/app/make-post"
@layout MainLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject Supabase.Client Supabase
@inject CBOS.Components.Services.AuthService AuthService
@using CBOS.Components.Model

<div class="make-post-wrapper">
    <div class="make-post-container">
        <!-- Back Button -->
        <button class="back-button" @onclick="GoBack">
            <span class="back-arrow">←</span>
        </button>

        <!-- Title -->
        <h1 class="make-post-title">Make a Community Post</h1>

        <!-- Form -->
        <form @onsubmit="HandleSubmit">
            <!-- Description Section -->
            <div class="form-section">
                <label class="section-label">Add description to your post</label>
                <textarea 
                    class="post-textarea"
                    @bind="postDescription"
                    placeholder="Write your post here..."
                    rows="6">
                </textarea>
            </div>

            <!-- Media Section -->
            <div class="form-section">
                <label class="section-label">Add photo or video to your post (optional)</label>
                
                @if (!string.IsNullOrEmpty(mediaPreview))
                {
                    <div class="media-preview">
                        <img src="@mediaPreview" alt="Preview" />
                        <button type="button" class="remove-media-btn" @onclick="RemoveMedia">×</button>
                    </div>
                }

                <button type="button" class="attach-media-btn" @onclick="HandleAttachMedia">
                    Attach media
                </button>
                <InputFile 
                    @ref="fileInput" 
                    id="fileInputElement"
                    style="display:none;" 
                    accept="image/*,video/*"
                    OnChange="HandleFileUpload" 
                />
            </div>

            <!-- Notice Section -->
            <div class="notice-section">
                <h3 class="notice-title">Notice</h3>
                <p class="notice-text">
                    Your posts will be subject for approval first being posted at the community feed for regulation. Expect updates regarding the status of your post.
                </p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }

            <!-- Submit Button -->
            <button type="submit" class="submit-button" disabled="@isSubmitting">
                @(isSubmitting ? "Submitting..." : "Submit")
            </button>
        </form>

        @if (showSuccess)
        {
            <div class="success-overlay">
                <div class="success-card">
                    <h2>Post Submitted!</h2>
                    <p>Your post is pending admin approval and will appear in the feed once approved.</p>
                    <button type="button" class="submit-button" @onclick="GoBack">Back to Feed</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string postDescription = "";
    private string mediaPreview = "";
    private InputFile? fileInput;
    private bool isSubmitting;
    private bool showSuccess;
    private string errorMessage = "";

    // TODO: Replace with logged-in user ID once Raim's session auth is fully integrated.
    // For now, this is used as a fallback if AuthService has no session.
    private const long FALLBACK_USER_ID = 1;
    private const long FALLBACK_BARANGAY_ID = 1;

    private void GoBack()
    {
        Navigation.NavigateTo("/app/feed");
    }

    private async Task HandleAttachMedia()
    {
        await TriggerFileInput();
    }

    private async Task TriggerFileInput()
    {
        try
        {
            await JS.InvokeVoidAsync("clickElement", "fileInputElement");
        }
        catch
        {
            // Fallback if JS interop fails
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        await ProcessFileUpload(e);
    }

    private async Task ProcessFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.GetMultipleFiles().FirstOrDefault();
        if (file != null)
        {
            var stream = file.OpenReadStream(maxAllowedSize: 5242880); // 5MB
            var bytes = new byte[stream.Length];
            await stream.ReadAsync(bytes);
            mediaPreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
            await stream.DisposeAsync();
        }
    }

    private void RemoveMedia()
    {
        mediaPreview = "";
    }

    private async Task HandleSubmit()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(postDescription))
        {
            errorMessage = "Please enter a description for your post.";
            return;
        }

        isSubmitting = true;

        try
        {
            long userId;
            long barangayId;
            string author;

            if (AuthService.IsAuthenticated && !string.IsNullOrEmpty(AuthService.UserEmail))
            {
                var profile = await Supabase
                    .From<UserProfile>()
                    .Match(new Dictionary<string, string> { { "emailaddress", AuthService.UserEmail } })
                    .Single();

                if (profile == null)
                {
                    errorMessage = "Unable to find your user profile. Please log in again.";
                    return;
                }

                userId = profile.Id;
                barangayId = profile.BarangayId ?? FALLBACK_BARANGAY_ID;
                author = $"{profile.FirstName} {profile.LastName}".Trim();
            }
            else
            {
                userId = FALLBACK_USER_ID;
                barangayId = FALLBACK_BARANGAY_ID;
                author = "Test User";
            }

            var newPost = new UserPost
            {
                UserId = userId,
                BarangayId = barangayId,
                Title = "",
                Author = author,
                Description = postDescription.Trim(),
                MediaLink = new List<string>()
            };

            var insertedPost = await Supabase.From<UserPost>().Insert(newPost);
            var postId = insertedPost.Models.FirstOrDefault()?.Id ?? 0;

            if (postId == 0)
            {
                errorMessage = "Post was created but the ID could not be retrieved.";
                return;
            }

            try
            {
                var ticket = new Ticket
                {
                    Type = "post",
                    SourceId = postId,
                    SubmittedBy = userId,
                    Status = "Pending"
                };

                await Supabase.From<Ticket>().Insert(ticket);
            }
            catch
            {
                // Compensating delete: if ticket creation fails, remove the orphaned post
                // so it doesn't end up invisible to the moderation queue.
                await Supabase.From<UserPost>()
                    .Where(p => p.Id == postId)
                    .Delete();
                throw;
            }

            postDescription = "";
            mediaPreview = "";
            showSuccess = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to submit post: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}

<style>
.make-post-wrapper {
    background: linear-gradient(135deg, #00a8e8 0%, #0078d4 100%);
    min-height: 100vh;
    padding: 20px;
}

.make-post-container {
    background: white;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    max-width: 900px;
    margin: 40px auto;
    padding: 40px;
    position: relative;
}

.back-button {
    position: absolute;
    top: 30px;
    left: 30px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 28px;
    color: #0078d4;
    padding: 8px 12px;
    transition: opacity 0.2s;
}

.back-button:hover {
    opacity: 0.7;
}

.back-arrow {
    display: inline-block;
}

.make-post-title {
    text-align: center;
    color: #0078d4;
    font-size: 2.5rem;
    font-weight: 600;
    margin: 0 0 40px 0;
    padding-top: 20px;
}

.form-section {
    margin-bottom: 30px;
}

.section-label {
    display: block;
    color: #666;
    font-size: 1rem;
    margin-bottom: 12px;
    font-weight: 500;
}

.post-textarea {
    width: 100%;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 16px;
    font-size: 0.95rem;
    font-family: inherit;
    color: #333;
    resize: vertical;
    background-color: #f5f5f5;
    transition: border-color 0.2s;
}

.post-textarea:focus {
    outline: none;
    border-color: #0078d4;
    background-color: #fff;
}

.post-textarea::placeholder {
    color: #999;
}

.media-preview {
    position: relative;
    margin-bottom: 12px;
    border-radius: 8px;
    overflow: hidden;
    max-width: 300px;
}

.media-preview img {
    width: 100%;
    height: auto;
    display: block;
}

.remove-media-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0, 0, 0, 0.6);
    color: white;
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    font-size: 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
}

.remove-media-btn:hover {
    background: rgba(0, 0, 0, 0.8);
}

.attach-media-btn {
    background-color: #0078d4;
    color: white;
    border: none;
    border-radius: 24px;
    padding: 10px 24px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s;
}

.attach-media-btn:hover {
    background-color: #005fa3;
}

.notice-section {
    background-color: #f0f8ff;
    border-left: 4px solid #0078d4;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 30px;
}

.notice-title {
    margin: 0 0 10px 0;
    color: #0078d4;
    font-size: 1.1rem;
    font-weight: 600;
}

.notice-text {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
    line-height: 1.6;
    font-style: italic;
}

.submit-button {
    width: 100%;
    background-color: #0078d4;
    color: white;
    border: none;
    border-radius: 24px;
    padding: 14px 32px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
}

.submit-button:hover {
    background-color: #005fa3;
}

.submit-button:active {
    transform: scale(0.98);
}

.submit-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.error-message {
    background-color: #fef2f2;
    color: #e50000;
    border: 1px solid #f5a0a0;
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 16px;
    font-size: 0.9rem;
}

.success-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.success-card {
    background: white;
    border-radius: 16px;
    padding: 40px;
    max-width: 420px;
    text-align: center;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
}

.success-card h2 {
    color: #0078d4;
    margin: 0 0 12px 0;
    font-size: 1.5rem;
}

.success-card p {
    color: #666;
    margin: 0 0 24px 0;
    font-size: 0.95rem;
    line-height: 1.5;
}
</style>

