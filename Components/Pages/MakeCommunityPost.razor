@page "/app/make-post"
@layout MainLayout
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="make-post-wrapper">
    <div class="make-post-container">
        <!-- Back Button -->
        <button class="back-button" @onclick="GoBack">
            <span class="back-arrow">←</span>
        </button>

        <!-- Title -->
        <h1 class="make-post-title">Make a Community Post</h1>

        <!-- Form -->
        <form @onsubmit="HandleSubmit">
            <!-- Description Section -->
            <div class="form-section">
                <label class="section-label">Add description to your post</label>
                <textarea 
                    class="post-textarea"
                    @bind="postDescription"
                    placeholder="Write your post here..."
                    rows="6">
                </textarea>
            </div>

            <!-- Media Section -->
            <div class="form-section">
                <label class="section-label">Add photo or video to your post (optional)</label>
                
                @if (!string.IsNullOrEmpty(mediaPreview))
                {
                    <div class="media-preview">
                        <img src="@mediaPreview" alt="Preview" />
                        <button type="button" class="remove-media-btn" @onclick="RemoveMedia">×</button>
                    </div>
                }

                <button type="button" class="attach-media-btn" @onclick="HandleAttachMedia">
                    Attach media
                </button>
                <InputFile 
                    @ref="fileInput" 
                    id="fileInputElement"
                    style="display:none;" 
                    accept="image/*,video/*"
                    OnChange="HandleFileUpload" 
                />
            </div>

            <!-- Notice Section -->
            <div class="notice-section">
                <h3 class="notice-title">Notice</h3>
                <p class="notice-text">
                    Your posts will be subject for approval first being posted at the community feed for regulation. Expect updates regarding the status of your post.
                </p>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="submit-button">
                Submit
            </button>
        </form>
    </div>
</div>

@code {
    private string postDescription = "";
    private string mediaPreview = "";
    private InputFile fileInput;

    private void GoBack()
    {
        Navigation.NavigateTo("/app");
    }

    private async Task HandleAttachMedia()
    {
        await TriggerFileInput();
    }

    private async Task TriggerFileInput()
    {
        try
        {
            await JS.InvokeVoidAsync("clickElement", "fileInputElement");
        }
        catch
        {
            // Fallback if JS interop fails
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        await ProcessFileUpload(e);
    }

    private async Task ProcessFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.GetMultipleFiles().FirstOrDefault();
        if (file != null)
        {
            var stream = file.OpenReadStream(maxAllowedSize: 5242880); // 5MB
            var bytes = new byte[stream.Length];
            await stream.ReadAsync(bytes);
            mediaPreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
            await stream.DisposeAsync();
        }
    }

    private void RemoveMedia()
    {
        mediaPreview = "";
    }

    private async Task HandleSubmit()
    {
        // TODO: Implement post submission logic
        // This should send the post data (description + media) to your backend
        Console.WriteLine($"Post submitted: {postDescription}");
        postDescription = "";
        mediaPreview = "";
    }
}

